@using Microsoft.AspNetCore.Components
@inject NavigationManager Navigation

<aside class="app-sidebar @(IsHomePage ? "app-sidebar-home" : null)" aria-label="Navegacao principal">
    <div class="sidebar-brand" aria-label="Blue Atelier">
        <span class="sidebar-brand-mark @(IsHomePage ? "sidebar-brand-mark-home" : null)" aria-hidden="true">
            @if (IsHomePage)
            {
                <span class="sidebar-brand-triangle"></span>
            }
            else
            {
                <span>BA</span>
            }
        </span>
        <span class="sidebar-brand-text">Blue Atelier</span>
    </div>

    <nav class="sidebar-nav">
        <NavLink class="sidebar-link" href="/" Match="NavLinkMatch.All">
            <span class="sidebar-icon" aria-hidden="true"><AppIcon Name="home" /></span>
            <span>@(IsHomePage ? "Home" : "Inicio")</span>
        </NavLink>

        <a class="sidebar-link @(IsCollectionsNavActive ? "active" : null)" href="/colecoes">
            <span class="sidebar-icon" aria-hidden="true"><AppIcon Name="collections" /></span>
            <span>@(IsHomePage ? "Collections" : "Colecoes")</span>
        </a>

        @foreach (var item in FutureItems)
        {
            if (IsHomePage && item.HasDividerBefore)
            {
                <span class="sidebar-home-divider" aria-hidden="true"></span>
            }

            <a class="sidebar-link sidebar-link-disabled @(IsFutureItemActive(item) ? "active" : null)" href="#" aria-disabled="true" @onclick:preventDefault>
                <span class="sidebar-icon" aria-hidden="true"><AppIcon Name="@item.Icon" /></span>
                <span>@(IsHomePage ? item.HomeLabel : item.Label)</span>
            </a>
        }
    </nav>

    @if (IsHomePage)
    {
        <div class="sidebar-home-action">
            <AppButton Variant="primary" Class="sidebar-new-collection">+ New Collection</AppButton>
        </div>
    }
</aside>

@code {
    private static readonly SidebarItem[] FutureItems =
    [
        new("Modelos", "Models", "models"),
        new("Fila de Impressao", "Print Queue", "print"),
        new("Arquivos Recentes", "Recent Files", "recent"),
        new("Materiais", "Materials", "materials", true),
        new("Favoritos", "Favorites", "favorites"),
        new("Busca", "Search", "search"),
        new("Configuracoes", "Settings", "settings")
    ];

    private bool IsHomePage
    {
        get
        {
            var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/');
            return string.IsNullOrWhiteSpace(relativePath);
        }
    }

    private bool IsFutureItemActive(SidebarItem item)
    {
        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/');
        return item.Icon == "models"
            && (string.Equals(relativePath, "colecoes/eldritch-horrors/modelos/cthulhu-idol", StringComparison.OrdinalIgnoreCase)
                || string.Equals(relativePath, "colecoes/eldritch-horrors/modelos/cthulhu-idol/arquivos", StringComparison.OrdinalIgnoreCase));
    }

    private bool IsCollectionsNavActive
    {
        get
        {
            var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/');
            return string.Equals(relativePath, "colecoes", StringComparison.OrdinalIgnoreCase)
                || string.Equals(relativePath, "colecoes/eldritch-horrors", StringComparison.OrdinalIgnoreCase)
                || string.Equals(relativePath, "colecoes/eldritch-horrors/modelos/cthulhu-idol/galeria", StringComparison.OrdinalIgnoreCase)
                || string.Equals(relativePath, "colecoes/eldritch-horrors/modelos/cthulhu-idol/galeria/main-reference", StringComparison.OrdinalIgnoreCase);
        }
    }

    private sealed record SidebarItem(string Label, string HomeLabel, string Icon, bool HasDividerBefore = false);
}
