<aside class="app-sidebar" aria-label="Navegacao principal">
    <div class="sidebar-brand" aria-label="Blue Atelier">
        <span class="sidebar-brand-mark">BA</span>
        <span class="sidebar-brand-text">Blue Atelier</span>
    </div>

    <nav class="sidebar-nav">
        <NavLink class="sidebar-link" href="/" Match="NavLinkMatch.All">
            <span class="sidebar-icon" aria-hidden="true">IN</span>
            <span>Inicio</span>
        </NavLink>

        @foreach (var item in FutureItems)
        {
            <a class="sidebar-link sidebar-link-disabled" href="#" aria-disabled="true" @onclick:preventDefault>
                <span class="sidebar-icon" aria-hidden="true">@item.Icon</span>
                <span>@item.Label</span>
            </a>
        }
    </nav>
</aside>

@code {
    private static readonly SidebarItem[] FutureItems =
    [
        new("Colecoes", "CO"),
        new("Modelos", "MO"),
        new("Fila de Impressao", "FI"),
        new("Arquivos Recentes", "AR"),
        new("Materiais", "MA"),
        new("Favoritos", "FA"),
        new("Busca", "BU"),
        new("Configuracoes", "CF")
    ];

    private sealed record SidebarItem(string Label, string Icon);
}
