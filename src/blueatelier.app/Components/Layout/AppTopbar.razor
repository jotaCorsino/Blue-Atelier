@using Microsoft.AspNetCore.Components
@inject NavigationManager Navigation

<header class="app-topbar @(IsHomePage ? "app-topbar-home" : null)">
    <label class="topbar-search" aria-label="Busca visual provisoria">
        <span aria-hidden="true">S</span>
        <input type="search" placeholder="@SearchPlaceholder" disabled />
    </label>

    @if (IsCollectionsPage)
    {
        <div class="topbar-actions" aria-label="Acoes de colecoes">
            <AppButton Variant="ghost">Importar pasta</AppButton>
            <AppButton Variant="primary">+ Nova colecao</AppButton>
        </div>
    }
    else if (IsImageViewerPage)
    {
        <div class="topbar-actions" aria-label="Acoes da visualizacao de imagem">
            <a class="topbar-link-button" href="/colecoes/eldritch-horrors/modelos/cthulhu-idol/galeria">
                <span aria-hidden="true">&lt;</span>
                <span>Back to Gallery</span>
            </a>
        </div>
    }
    else if (IsLinkedFilesPage)
    {
        <div class="topbar-actions" aria-label="Acoes de arquivos vinculados">
            <a class="topbar-link-button" href="/colecoes/eldritch-horrors/modelos/cthulhu-idol">
                <span aria-hidden="true">&lt;</span>
                <span>Back to Model Detail</span>
            </a>
        </div>
    }
    else if (IsModelsPage)
    {
        <div class="topbar-status" role="status">
            <span class="status-dot" aria-hidden="true"></span>
            <span>Modelos mockados</span>
        </div>
    }
    else if (IsFavoritesPage)
    {
        <div class="topbar-status" role="status">
            <span class="status-dot" aria-hidden="true"></span>
            <span>Favoritos mockados</span>
        </div>
    }
    else if (IsSearchPage)
    {
        <div class="topbar-status" role="status">
            <span class="status-dot" aria-hidden="true"></span>
            <span>Busca visual</span>
        </div>
    }
    else if (IsSettingsPage)
    {
        <div class="topbar-status" role="status">
            <span class="status-dot" aria-hidden="true"></span>
            <span>Configuracoes mockadas</span>
        </div>
    }
    else if (IsModelGalleryPage)
    {
        <div class="topbar-actions" aria-label="Acoes da galeria do modelo">
            <a class="topbar-link-button" href="/colecoes/eldritch-horrors/modelos/cthulhu-idol">
                <span aria-hidden="true">&lt;</span>
                <span>Back to Cthulhu Idol</span>
            </a>
        </div>
    }
    else if (IsModelDetailPage)
    {
        <div class="topbar-actions" aria-label="Acoes do detalhe do modelo">
            <a class="topbar-link-button" href="/colecoes/eldritch-horrors">
                <span aria-hidden="true">&lt;</span>
                <span>Back to Eldritch Horrors</span>
            </a>
        </div>
    }
    else if (IsCollectionDetailPage)
    {
        <span class="topbar-spacer" aria-hidden="true"></span>
    }
    else if (IsHomePage)
    {
        <div class="topbar-status topbar-network-status" role="status">
            <span class="status-dot status-dot-muted" aria-hidden="true"></span>
            <span>Network path offline: Z:\My Miniatures</span>
        </div>
    }
    else
    {
        <div class="topbar-status">
            <span class="status-dot" aria-hidden="true"></span>
            <span>Fundacao visual</span>
        </div>
    }
</header>

@code {
    private bool IsCollectionsPage
    {
        get
        {
            var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/');
            return string.Equals(relativePath, "colecoes", StringComparison.OrdinalIgnoreCase);
        }
    }

    private bool IsHomePage
    {
        get
        {
            var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/');
            return string.IsNullOrWhiteSpace(relativePath);
        }
    }

    private bool IsCollectionDetailPage
    {
        get
        {
            var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/');
            return string.Equals(relativePath, "colecoes/eldritch-horrors", StringComparison.OrdinalIgnoreCase);
        }
    }

    private bool IsModelDetailPage
    {
        get
        {
            var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/');
            return string.Equals(relativePath, "colecoes/eldritch-horrors/modelos/cthulhu-idol", StringComparison.OrdinalIgnoreCase);
        }
    }

    private bool IsModelGalleryPage
    {
        get
        {
            var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/');
            return string.Equals(relativePath, "colecoes/eldritch-horrors/modelos/cthulhu-idol/galeria", StringComparison.OrdinalIgnoreCase);
        }
    }

    private bool IsImageViewerPage
    {
        get
        {
            var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/');
            return string.Equals(relativePath, "colecoes/eldritch-horrors/modelos/cthulhu-idol/galeria/main-reference", StringComparison.OrdinalIgnoreCase);
        }
    }

    private bool IsLinkedFilesPage
    {
        get
        {
            var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/');
            return string.Equals(relativePath, "colecoes/eldritch-horrors/modelos/cthulhu-idol/arquivos", StringComparison.OrdinalIgnoreCase);
        }
    }

    private bool IsModelsPage
    {
        get
        {
            var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/');
            return string.Equals(relativePath, "modelos", StringComparison.OrdinalIgnoreCase);
        }
    }

    private bool IsFavoritesPage
    {
        get
        {
            var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/');
            return string.Equals(relativePath, "favoritos", StringComparison.OrdinalIgnoreCase);
        }
    }

    private bool IsSearchPage
    {
        get
        {
            var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/');
            return string.Equals(relativePath, "busca", StringComparison.OrdinalIgnoreCase);
        }
    }

    private bool IsSettingsPage
    {
        get
        {
            var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/');
            return string.Equals(relativePath, "configuracoes", StringComparison.OrdinalIgnoreCase);
        }
    }

    private string SearchPlaceholder
    {
        get
        {
            if (IsCollectionsPage)
            {
                return "Buscar colecoes...";
            }

            if (IsModelsPage)
            {
                return "Buscar modelos...";
            }

            if (IsFavoritesPage)
            {
                return "Buscar favoritos...";
            }

            if (IsSearchPage)
            {
                return "Buscar no atelier...";
            }

            if (IsSettingsPage)
            {
                return "Buscar configuracoes...";
            }

            if (IsHomePage || IsCollectionDetailPage || IsModelDetailPage || IsModelGalleryPage || IsImageViewerPage || IsLinkedFilesPage)
            {
                return "Search models, prints, paints...";
            }

            return "Buscar modelos, colecoes, arquivos...";
        }
    }
}
