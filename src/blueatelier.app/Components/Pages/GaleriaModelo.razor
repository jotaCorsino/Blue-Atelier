@page "/colecoes/{ColecaoSlug}/modelos/{ModeloSlug}/galeria"
@using BlueAtelier.Application.Contratos
@using BlueAtelier.Application.Modelos
@using BlueAtelier.Domain.Enums
@inject IModeloServico ModeloServico
@inject IImagemModeloServico ImagemModeloServico

<section class="model-gallery-page" aria-labelledby="model-gallery-page-title">
    <a class="collection-detail-back" href="@ModelPath">
        <span aria-hidden="true">&lt;</span>
        <span>Voltar para @ModelName</span>
    </a>

    <header class="model-gallery-header">
        <div class="model-gallery-header-copy page-heading">
            <h1 class="page-title" id="model-gallery-page-title">Galeria do Modelo</h1>
            <p class="page-description">Imagens, referências e registros visuais do modelo.</p>
            <div class="model-gallery-context" aria-label="Contexto da galeria">
                <span>@ModelName</span>
                <span aria-hidden="true">/</span>
                <a href="@CollectionPath">@CollectionName</a>
            </div>
        </div>

        <div class="model-gallery-actions" aria-label="Ações visuais da galeria">
            <button class="model-gallery-action model-gallery-action-primary" type="button">
                <span aria-hidden="true">+</span>
                Adicionar imagem
            </button>
            <button class="model-gallery-action" type="button">
                <AppIcon Name="image" />
                Adicionar referência
            </button>
            <button class="model-gallery-action" type="button">
                <AppIcon Name="settings" />
                Organizar galeria
            </button>
            <button class="model-gallery-action" type="button">
                <AppIcon Name="edit" />
                Editar informações
            </button>
        </div>
    </header>

    <nav class="model-gallery-filters" aria-label="Filtros visuais da galeria">
        @foreach (var filter in Filters)
        {
            <button class="model-gallery-filter @(filter.IsActive ? "model-gallery-filter-active" : null)" type="button">
                @filter.Label
            </button>
        }
    </nav>

    <section class="model-gallery-masonry" aria-label="Mosaico visual da galeria">
        @if (IsLoading)
        {
            <AppStateBlock
                Variant="loading"
                Title="Carregando galeria"
                Description="Buscando metadados locais de imagens."
                IsCompact="true" />
        }
        else if (Model is null)
        {
            <AppStateBlock
                Variant="unavailable"
                Title="Modelo não encontrado"
                Description="Não foi possível encontrar este modelo no banco local."
                ActionLabel="Voltar para Modelos"
                IsCompact="true" />
        }
        else if (GalleryItems.Count == 0)
        {
            <AppStateBlock
                Variant="empty"
                Title="Nenhuma imagem vinculada"
                Description="Este modelo ainda não possui metadados de imagens na galeria."
                IsCompact="true" />
        }
        else
        {
            @foreach (var item in GalleryItems)
            {
                @if (!string.IsNullOrWhiteSpace(item.Route))
                {
                    <a class="model-gallery-card gallery-card-@item.Size" href="@item.Route" aria-label="Abrir imagem @item.Title">
                        <div class="model-gallery-art gallery-art-@item.Art" aria-hidden="true">
                            @if (item.IsCover)
                            {
                                <span class="gallery-cover-badge">Capa</span>
                            }

                            <span class="gallery-edit-affordance">
                                <AppIcon Name="edit" />
                                <span>Editar</span>
                            </span>
                            <span class="gallery-art-shape"></span>
                        </div>

                        <div class="model-gallery-card-body">
                            <div>
                                <h2>@item.Title</h2>
                                <span>@item.Category</span>
                            </div>
                            <p>@item.Description</p>
                        </div>
                    </a>
                }
                else
                {
                    <article class="model-gallery-card gallery-card-@item.Size">
                        <div class="model-gallery-art gallery-art-@item.Art" aria-hidden="true">
                            @if (item.IsCover)
                            {
                                <span class="gallery-cover-badge">Capa</span>
                            }

                            <span class="gallery-edit-affordance">
                                <AppIcon Name="edit" />
                                <span>Editar</span>
                            </span>
                            <span class="gallery-art-shape"></span>
                        </div>

                        <div class="model-gallery-card-body">
                            <div>
                                <h2>@item.Title</h2>
                                <span>@item.Category</span>
                            </div>
                            <p>@item.Description</p>
                        </div>
                    </article>
                }
            }
        }
    </section>
</section>

@code {
    [Parameter]
    public string? ColecaoSlug { get; set; }

    [Parameter]
    public string? ModeloSlug { get; set; }

    private bool IsLoading { get; set; } = true;

    private ModeloDetalhe? Model { get; set; }

    private IReadOnlyList<GalleryItem> GalleryItems { get; set; } = [];

    private string ModelName => Model?.Nome ?? "Cthulhu Idol";

    private string CollectionName => Model?.ColecaoNome ?? "Eldritch Horrors";

    private string CollectionPath => Model is null
        ? "/colecoes/eldritch-horrors"
        : $"/colecoes/{Model.ColecaoSlug}";

    private string ModelPath => Model is null
        ? "/colecoes/eldritch-horrors/modelos/cthulhu-idol"
        : $"/colecoes/{Model.ColecaoSlug}/modelos/{Model.Slug}";

    private string GalleryPath => Model is null
        ? "/colecoes/eldritch-horrors/modelos/cthulhu-idol/galeria"
        : $"/colecoes/{Model.ColecaoSlug}/modelos/{Model.Slug}/galeria";

    private static readonly GalleryFilter[] Filters =
    [
        new("Todas", true),
        new("Referências", false),
        new("Impressao", false),
        new("Pintura", false),
        new("Finalizadas", false),
        new("Notas visuais", false)
    ];

    protected override async Task OnParametersSetAsync()
    {
        IsLoading = true;
        GalleryItems = [];
        Model = await ModeloServico.ObterDetalhePorSlugAsync(
            ColecaoSlug ?? string.Empty,
            ModeloSlug ?? string.Empty);

        if (Model is not null)
        {
            var imagens = await ImagemModeloServico.ListarPorModeloAsync(Model.Id);
            GalleryItems = imagens
                .Select((imagem, index) => CriarGalleryItem(imagem, index, GalleryPath))
                .ToList();
        }

        IsLoading = false;
    }

    private static GalleryItem CriarGalleryItem(
        ImagemModeloResumo imagem,
        int index,
        string galleryPath)
    {
        var route = imagem.EhPrincipal
            ? $"{galleryPath}/main-reference"
            : null;

        return new GalleryItem(
            imagem.Titulo,
            FormatCategory(imagem.Tipo),
            FormatDescription(imagem),
            FormatArt(imagem, index),
            FormatSize(index),
            imagem.EhPrincipal,
            route);
    }

    private static string FormatCategory(TipoImagemModelo tipo)
    {
        return tipo switch
        {
            TipoImagemModelo.Progresso => "Pintura",
            TipoImagemModelo.Final => "Finalizadas",
            TipoImagemModelo.Textura => "Notas visuais",
            TipoImagemModelo.Outro => "Notas visuais",
            _ => "Referências"
        };
    }

    private static string FormatDescription(ImagemModeloResumo imagem)
    {
        if (!string.IsNullOrWhiteSpace(imagem.Observacao))
        {
            return imagem.Observacao;
        }

        return imagem.CaminhoLocal;
    }

    private static string FormatArt(ImagemModeloResumo imagem, int index)
    {
        if (imagem.EhPrincipal)
        {
            return "main";
        }

        return index switch
        {
            1 => "front",
            2 => "primer",
            3 => "green",
            4 => "final",
            5 => "stone",
            6 => "tentacle",
            _ => "purple"
        };
    }

    private static string FormatSize(int index)
    {
        return index switch
        {
            0 => "tall",
            1 => "wide",
            2 => "square",
            3 => "tall",
            4 => "square",
            _ => "wide"
        };
    }

    private sealed record GalleryFilter(string Label, bool IsActive);

    private sealed record GalleryItem(
        string Title,
        string Category,
        string Description,
        string Art,
        string Size,
        bool IsCover,
        string? Route = null);
}
