@page "/configuracoes"
@using BlueAtelier.Application.Contratos
@using BlueAtelier.Application.Modelos
@inject IConfiguracoesServico ConfiguracoesServico

<section class="settings-page settings-module-page settings-stitch-page" aria-labelledby="settings-title">
    <header class="settings-header settings-module-header settings-stitch-header page-heading">
        <h1 class="page-title" id="settings-title">Configurações</h1>
        <p class="page-description">Gerencie caminhos, aparência, backup e preferências do seu atelier.</p>
    </header>

    <div class="settings-layout settings-module-layout settings-stitch-layout">
        <nav class="settings-secondary-nav settings-stitch-nav" aria-label="Categorias de configurações">
            @foreach (var item in Categories)
            {
                @if (item.Href is null)
                {
                    <button class="settings-stitch-nav-item @(item.IsActive ? "settings-stitch-nav-item-active" : null)"
                            type="button"
                            aria-pressed="@item.IsActive">
                        @item.Label
                    </button>
                }
                else
                {
                    <a class="settings-stitch-nav-item @(item.IsActive ? "settings-stitch-nav-item-active" : null)"
                       href="@item.Href"
                       aria-current="@(item.IsActive ? "page" : null)">
                        @item.Label
                    </a>
                }
            }
        </nav>

        <main class="settings-content settings-module-content settings-stitch-panels" aria-label="Painéis de configurações mockadas">
            <section class="settings-stitch-card settings-stitch-card-wide" aria-labelledby="settings-paths-title">
                <h2 id="settings-paths-title">Caminhos principais</h2>

                <div class="settings-path-grid">
                    @foreach (var path in MainPaths)
                    {
                        <div class="settings-path-item">
                            <div class="settings-path-label-row">
                                <label>@path.Label</label>
                                <span class="settings-path-status settings-path-status-ok">
                                    <AppIcon Name="check" />
                                    Status: OK
                                </span>
                            </div>

                            <input type="text" value="@path.Value" readonly aria-label="@path.Label" />

                            <div class="settings-path-actions">
                                <button type="button">
                                    <AppIcon Name="plus" />
                                    Alterar
                                </button>
                                <button type="button">
                                    <AppIcon Name="external" />
                                    Testar
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <div class="settings-stitch-middle">
                <section class="settings-stitch-card settings-network-card" aria-labelledby="settings-network-title">
                    <h2 id="settings-network-title">Rede</h2>

                    <div class="settings-network-field">
                        <div class="settings-path-label-row">
                            <label>Destino de arquivos preparados</label>
                            <span class="settings-path-status settings-path-status-offline">
                                <AppIcon Name="alert" />
                                Offline
                            </span>
                        </div>

                        <input type="text" value="@ConfiguracoesGerais.DiretorioBackups" readonly aria-label="Destino de arquivos preparados" />
                    </div>
                </section>

                <section class="settings-stitch-card settings-appearance-card" aria-labelledby="settings-appearance-title">
                    <h2 id="settings-appearance-title">Aparência</h2>

                    <div class="settings-theme-grid" aria-label="Tema visual mockado">
                        @foreach (var theme in Themes)
                        {
                            <button class="settings-theme-option @(theme.IsActive ? "settings-theme-option-active" : null) @(theme.IsDark ? "settings-theme-option-dark" : null)"
                                    type="button"
                                    aria-pressed="@theme.IsActive">
                                <AppIcon Name="@theme.Icon" />
                                <span>@theme.Label</span>
                            </button>
                        }
                    </div>

                    <div class="settings-accent-picker" aria-label="Cor de destaque mockada">
                        <span>Cor de destaque</span>
                        <div>
                            @foreach (var color in AccentColors)
                            {
                                <button class="settings-accent-swatch @(color.IsActive ? "settings-accent-swatch-active" : null)"
                                        type="button"
                                        title="@color.Label"
                                        aria-label="@color.Label"
                                        style="@($"--settings-swatch: {color.Value};")">
                                </button>
                            }
                        </div>
                    </div>
                </section>
            </div>

            <section class="settings-stitch-card settings-stitch-card-wide" aria-labelledby="settings-programs-title">
                <h2 id="settings-programs-title">Programas padrão</h2>

                <div class="settings-program-grid">
                    @foreach (var program in Programs)
                    {
                        <label class="settings-program-field">
                            <span>@program.Label</span>
                            <span class="settings-program-select">
                                <span class="settings-program-logo settings-program-logo-@program.Tone" aria-hidden="true">@program.Initials</span>
                                <select aria-label="@program.Label">
                                    <option>@program.Value</option>
                                </select>
                                <AppIcon Name="chevron-down" />
                            </span>
                        </label>
                    }
                </div>
            </section>
        </main>
    </div>
</section>

@code {
    private static readonly SettingsCategory[] Categories =
    [
        new("Geral", true, "/configuracoes"),
        new("Caminhos", false, "/configuracoes/caminhos"),
        new("Aparência", false, "/configuracoes/aparencia"),
        new("Backup", false, "/configuracoes/backup"),
        new("Modelo de Pastas", false, "/configuracoes/modelo-pastas"),
        new("Dados do App", false, null)
    ];

    private ConfiguracoesGeraisResumo ConfiguracoesGerais { get; set; } = ConfiguracoesPadrao;

    private IReadOnlyList<SettingsPath> MainPaths =>
    [
        new("Pasta principal do atelier", ConfiguracoesGerais.DiretorioRaiz),
        new("Pasta de coleções", ConfiguracoesGerais.DiretorioModelos)
    ];

    private IReadOnlyList<SettingsTheme> Themes =>
    [
        new("Tema claro", "sun", TemaAtivo("light"), false),
        new("Tema escuro", "moon", TemaAtivo("dark"), true),
        new("Automático", "monitor", TemaAtivo("system"), false)
    ];

    private IReadOnlyList<SettingsAccent> AccentColors =>
    [
        new("Azul", "#625bd8", CorAtiva("blue")),
        new("Preto azulado", "#21222d", CorAtiva("ink")),
        new("Argila", "#a7551d", CorAtiva("clay")),
        new("Ambar", "#d99b12", CorAtiva("amber")),
        new("Verde", "#3f6b5f", CorAtiva("green")),
        new("Teal", "#2f8f8c", CorAtiva("teal")),
        new("Azul claro", "#74aef8", CorAtiva("light-blue")),
        new("Violeta", "#8d65db", CorAtiva("violet")),
        new("Rosa", "#d84b8a", CorAtiva("rose"))
    ];

    private static readonly SettingsProgram[] Programs =
    [
        new("Slicer", "Lychee Slicer", "LY", "lychee"),
        new("Modelagem", "Blender", "BL", "blender")
    ];

    private static readonly ConfiguracoesGeraisResumo ConfiguracoesPadrao = new(
        "pt-BR",
        "system",
        "comfortable",
        "blue",
        "C:/BlueAtelier",
        "C:/BlueAtelier/Modelos",
        "C:/BlueAtelier/Backups",
        false,
        DateTimeOffset.UtcNow);

    protected override async Task OnInitializedAsync()
    {
        ConfiguracoesGerais = await ConfiguracoesServico.ObterGeraisAsync();
    }

    private bool TemaAtivo(string tema)
    {
        return string.Equals(ConfiguracoesGerais.Tema, tema, StringComparison.OrdinalIgnoreCase);
    }

    private bool CorAtiva(string cor)
    {
        return string.Equals(ConfiguracoesGerais.CorDestaque, cor, StringComparison.OrdinalIgnoreCase);
    }

    private sealed record SettingsCategory(string Label, bool IsActive, string? Href);

    private sealed record SettingsPath(string Label, string Value);

    private sealed record SettingsTheme(string Label, string Icon, bool IsActive, bool IsDark);

    private sealed record SettingsAccent(string Label, string Value, bool IsActive);

    private sealed record SettingsProgram(string Label, string Value, string Initials, string Tone);
}
