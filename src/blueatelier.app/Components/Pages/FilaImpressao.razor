@page "/fila-impressao"

<section class="print-queue-page" aria-labelledby="print-queue-title">
    <header class="print-queue-header">
        <div class="print-queue-heading">
            <p>Fila local do atelier</p>
            <h1 id="print-queue-title">Fila de Impressao</h1>
            <span>Modelos prontos, em andamento e pendentes para impressao 3D.</span>
        </div>

        <div class="print-queue-overall-status" role="status">
            <span class="print-queue-status-dot" aria-hidden="true"></span>
            <div>
                <strong>1 item em impressao</strong>
                <small>6 itens mockados na fila visual</small>
            </div>
        </div>
    </header>

    <section class="print-queue-actions" aria-label="Acoes visuais da fila de impressao">
        <button class="print-queue-action print-queue-action-primary" type="button">
            <span aria-hidden="true">+</span>
            Adicionar a fila
        </button>
        <button class="print-queue-action" type="button">
            <AppIcon Name="upload" />
            Importar arquivo
        </button>
        <button class="print-queue-action" type="button">
            <AppIcon Name="reorder" />
            Reordenar fila
        </button>
        <button class="print-queue-action" type="button">
            <AppIcon Name="check" />
            Limpar concluidos
        </button>
    </section>

    <nav class="print-queue-filters" aria-label="Filtros visuais da fila de impressao">
        @foreach (var filter in Filters)
        {
            <button class="print-queue-filter @(filter.IsActive ? "print-queue-filter-active" : null)" type="button">
                @filter.Label
            </button>
        }
    </nav>

    <div class="print-queue-layout">
        <aside class="print-queue-summary" aria-label="Resumo da fila de impressao">
            @foreach (var item in SummaryItems)
            {
                <section class="print-queue-summary-card">
                    <span class="print-queue-summary-icon summary-@item.Tone" aria-hidden="true">
                        <AppIcon Name="@item.Icon" />
                    </span>
                    <span>@item.Label</span>
                    <strong>@item.Value</strong>
                </section>
            }

            <section class="print-queue-printer-card">
                <h2>Impressora Atual</h2>
                <div>
                    <span class="print-queue-printer-icon" aria-hidden="true">
                        <AppIcon Name="print" />
                    </span>
                    <div>
                        <strong>Elegoo Mars 3 Pro</strong>
                        <small><span aria-hidden="true"></span> Online e ociosa</small>
                    </div>
                </div>
            </section>

            <section class="print-queue-network-card">
                <span class="print-queue-warning-dot" aria-hidden="true"></span>
                <h2>Destino de rede offline</h2>
                <p>\\atelier-notebook\fila-impressao\</p>
                <small>Condicao visual normal. Nenhum caminho real foi acessado.</small>
            </section>
        </aside>

        <main class="print-queue-board" aria-label="Itens da fila de impressao">
            <div class="print-queue-board-header">
                <div>
                    <h2>Itens na Fila</h2>
                    <p>Total estimado: 18h 55m - 420 ml de resina</p>
                </div>
                <button type="button">
                    <AppIcon Name="reorder" />
                    Filtrar
                </button>
            </div>

            <div class="print-queue-table" role="table" aria-label="Lista visual de modelos na fila">
                <div class="print-queue-table-head" role="row">
                    <span>Modelo e destino</span>
                    <span>Material</span>
                    <span>Tempo</span>
                    <span>Status</span>
                    <span>Acao</span>
                </div>

                @foreach (var item in QueueItems)
                {
                    <article class="print-queue-row print-queue-row-@item.StatusTone" role="row">
                        <div class="print-queue-model-cell">
                            <div class="print-queue-thumb queue-thumb-@item.ThumbTone" aria-hidden="true">
                                <span></span>
                            </div>
                            <div>
                                <h3>@item.FileName</h3>
                                <p>@item.Context</p>
                                <small>Fila #@item.Position - @item.Priority</small>
                            </div>
                        </div>

                        <div class="print-queue-material-cell">
                            <strong>@item.Material</strong>
                            <span>@item.Printer</span>
                        </div>

                        <div class="print-queue-time-cell">
                            <strong>@item.Time</strong>
                            <span>@item.Date</span>
                        </div>

                        <div class="print-queue-status-cell">
                            <span class="print-queue-badge badge-@item.StatusTone">
                                <span aria-hidden="true"></span>
                                @item.Status
                            </span>
                        </div>

                        <div class="print-queue-item-actions" aria-label="Acoes visuais para @item.FileName">
                            <button type="button" title="Iniciar" aria-label="Iniciar @item.FileName">
                                <AppIcon Name="play" />
                            </button>
                            <button type="button" title="Pausar" aria-label="Pausar @item.FileName">
                                <AppIcon Name="pause" />
                            </button>
                            <button type="button" title="Editar" aria-label="Editar @item.FileName">
                                <AppIcon Name="edit" />
                            </button>
                            <button class="print-queue-danger-action" type="button" title="Remover" aria-label="Remover @item.FileName">
                                <AppIcon Name="trash" />
                            </button>
                        </div>
                    </article>
                }
            </div>
        </main>
    </div>
</section>

@code {
    private static readonly FilterItem[] Filters =
    [
        new("Todos", true),
        new("Prontos", false),
        new("Em impressao", false),
        new("Pausados", false),
        new("Concluidos", false),
        new("Com erro", false)
    ];

    private static readonly SummaryItem[] SummaryItems =
    [
        new("6", "Total na fila", "print", "blue"),
        new("3", "Prontos", "check", "green"),
        new("1", "Em impressao", "play", "blue"),
        new("1", "Concluido", "check", "slate"),
        new("18h 55m", "Tempo estimado", "recent", "amber"),
        new("420 ml", "Resina estimada", "materials", "green")
    ];

    private static readonly QueueItem[] QueueItems =
    [
        new("cthulhu-idol-ready.ctb", "Eldritch Horrors / Cthulhu Idol", "Alta prioridade", "6h 40m", "Resin grey", "Mars 3 Pro", "Agora", "Em impressao", "printing", "idol", 1),
        new("ancient-cultist.ctb", "Eldritch Horrors / Ancient Cultist", "Alta prioridade", "3h 15m", "Resin grey", "Mars 3 Pro", "Proximo", "Pronto", "ready", "cultist", 2),
        new("dungeon-tiles.ctb", "Tavern Dioramas / Dungeon Tiles", "Normal", "2h 10m", "ABS-like clear", "Saturn 2", "Hoje", "Pausado", "paused", "tiles", 3),
        new("abyssal-statue.ctb", "Eldritch Horrors / Abyssal Statue", "Normal", "5h 25m", "Resin grey", "Mars 3 Pro", "Hoje", "Pronto", "ready", "statue", 4),
        new("tentacle-beast.ctb", "Eldritch Horrors / Tentacle Beast", "Arquivo ausente", "--", "Resin grey", "Mars 3 Pro", "Revisar", "Arquivo ausente", "missing", "beast", 5),
        new("dragon-bust.ctb", "Dragon Busts / Dragon Bust", "Baixa prioridade", "1h 25m", "Deep green resin", "Saturn 2", "Ontem", "Concluido", "done", "dragon", 6)
    ];

    private sealed record FilterItem(string Label, bool IsActive);

    private sealed record SummaryItem(string Value, string Label, string Icon, string Tone);

    private sealed record QueueItem(
        string FileName,
        string Context,
        string Priority,
        string Time,
        string Material,
        string Printer,
        string Date,
        string Status,
        string StatusTone,
        string ThumbTone,
        int Position);
}
