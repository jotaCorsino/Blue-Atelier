@page "/colecoes"
@using BlueAtelier.Application.Contratos
@using BlueAtelier.Application.Modelos
@inject IColecaoServico ColecaoServico

<section class="collections-page" aria-labelledby="collections-title">
    <header class="collections-heading">
        <div class="page-heading">
            <h1 class="page-title" id="collections-title">Coleções</h1>
            <p class="page-description">Organize linhas, temas e grupos de modelos do atelier.</p>
        </div>

        <div class="collections-filter-pills" aria-label="Filtros visuais de coleções">
            @foreach (var filter in Filters)
            {
                <button class="collection-filter-pill @(filter.IsActive ? "collection-filter-pill-active" : null)" type="button">
                    @filter.Label
                </button>
            }
        </div>
    </header>

    <div class="collections-tools" aria-label="Ordenação visual provisória">
        <label class="collections-sort">
            <span>Ordenar</span>
            <select disabled>
                <option>Atualizadas recentemente</option>
                <option>Nome</option>
                <option>Quantidade de modelos</option>
                <option>Status</option>
            </select>
        </label>
    </div>

    <div class="collections-grid" aria-label="Mosaico de coleções">
        @foreach (var collection in Collections)
        {
            <a class="collections-card collections-card-link"
               href="@(collection.DetailPath ?? "#")"
               @onclick:preventDefault="@(collection.DetailPath is null)"
               aria-label="@($"Ver coleção {collection.Name}")">
                <div class="collections-card-cover @collection.CoverClass" aria-hidden="true">
                    <span class="card-edit-affordance">
                        <AppIcon Name="edit" />
                        <span>Editar</span>
                    </span>
                </div>

                <div class="collections-card-body">
                    <div class="collections-card-title-row">
                        <h2>@collection.Name</h2>
                        <span class="collections-status collections-status-@collection.StatusTone">@collection.Status</span>
                    </div>

                    <p class="collections-card-description">@collection.Description</p>

                    <div class="collections-card-tags" aria-label="@($"Tags de {collection.Name}")">
                        @foreach (var tag in collection.Tags)
                        {
                            <span>@tag</span>
                        }
                    </div>

                    <div class="collections-card-footer">
                        <span>@collection.ModelCount</span>
                        <span>@collection.UpdatedAt</span>
                        <span class="collections-card-action">
                            @(collection.DetailPath is null ? "Em breve" : "Ver coleção")
                            <AppIcon Name="arrow" />
                        </span>
                    </div>
                </div>
            </a>
        }
    </div>

    @if (ShowEmptyState)
    {
        <AppStateBlock
            Class="collections-empty-state"
            Variant="empty"
            Title="Nenhuma coleção criada ainda."
            Description="Crie a primeira linha do atelier para começar a organizar modelos, arquivos e referências."
            ActionLabel="Criar primeira coleção" />
    }
</section>

@code {
    private bool IsLoading { get; set; } = true;

    private IReadOnlyList<CollectionCard> Collections { get; set; } = [];

    private bool ShowEmptyState => !IsLoading && Collections.Count == 0;

    private static readonly FilterPill[] Filters =
    [
        new("Todas", true),
        new("Em andamento", false),
        new("Prontas", false),
        new("Pausadas", false),
        new("Arquivadas", false)
    ];

    private static readonly Dictionary<string, CollectionVisualMetadata> VisualMetadata = new(StringComparer.OrdinalIgnoreCase)
    {
        ["eldritch-horrors"] = new("8 modelos", "Em andamento", "progress", "Atualizada hoje", "cover-eldritch", ["dark fantasy", "resina"]),
        ["sci-fi-marines"] = new("15 modelos", "Pronta", "ready", "Atualizada ontem", "cover-marines", ["sci-fi", "stl"]),
        ["fantasy-adventurers"] = new("5 modelos", "Pausada", "muted", "Atualizada há 3 dias", "cover-adventurers", ["fantasia", "pintura"]),
        ["dragon-busts"] = new("2 modelos", "Em andamento", "progress", "Atualizada há 5 dias", "cover-dragons", ["busto", "criaturas"]),
        ["tavern-dioramas"] = new("1 modelo", "Pausada", "muted", "Atualizada há 1 semana", "cover-tavern", ["cenário", "diorama"]),
        ["ancient-ruins"] = new("10 modelos", "Pronta", "ready", "Atualizada há 1 semana", "cover-ruins", ["cenário", "bases"]),
        ["painting-studies"] = new("6 modelos", "Em andamento", "progress", "Atualizada há 2 semanas", "cover-painting", ["estudo", "cores"]),
        ["miniature-bases"] = new("18 modelos", "Arquivada", "archived", "Atualizada há 1 mês", "cover-bases", ["bases", "textura"])
    };

    private static readonly CollectionVisualMetadata DefaultVisualMetadata =
        new("0 modelos", "Em andamento", "progress", "Atualizada recentemente", "cover-eldritch", ["atelier"]);

    protected override async Task OnInitializedAsync()
    {
        var resumos = await ColecaoServico.ListarResumoAsync();

        Collections = resumos
            .Select(CriarCard)
            .ToList();

        IsLoading = false;
    }

    private static CollectionCard CriarCard(ColecaoResumo resumo)
    {
        var metadata = VisualMetadata.GetValueOrDefault(resumo.Slug, DefaultVisualMetadata);
        var status = resumo.EstaArquivada ? "Arquivada" : metadata.Status;
        var statusTone = resumo.EstaArquivada ? "archived" : metadata.StatusTone;
        var coverClass = !string.IsNullOrWhiteSpace(resumo.ImagemCapa)
                         && resumo.ImagemCapa.StartsWith("cover-", StringComparison.OrdinalIgnoreCase)
            ? resumo.ImagemCapa
            : metadata.CoverClass;

        return new CollectionCard(
            resumo.Nome,
            resumo.Descricao ?? string.Empty,
            metadata.ModelCount,
            status,
            statusTone,
            metadata.UpdatedAt,
            coverClass,
            metadata.Tags,
            CriarCaminhoDetalhe(resumo));
    }

    private static string? CriarCaminhoDetalhe(ColecaoResumo resumo)
    {
        return resumo.Slug.Equals("eldritch-horrors", StringComparison.OrdinalIgnoreCase)
            ? $"/colecoes/{resumo.Slug}"
            : null;
    }

    private sealed record FilterPill(string Label, bool IsActive);

    private sealed record CollectionVisualMetadata(
        string ModelCount,
        string Status,
        string StatusTone,
        string UpdatedAt,
        string CoverClass,
        string[] Tags);

    private sealed record CollectionCard(
        string Name,
        string Description,
        string ModelCount,
        string Status,
        string StatusTone,
        string UpdatedAt,
        string CoverClass,
        string[] Tags,
        string? DetailPath
    );
}
