@page "/configuracoes/modelo-pastas"
@using BlueAtelier.Application.Contratos
@using BlueAtelier.Application.Modelos
@inject IConfiguracoesServico ConfiguracoesServico

<section class="settings-page settings-module-page settings-stitch-page settings-folder-template-page" aria-labelledby="folder-template-title">
    <header class="settings-header settings-module-header settings-stitch-header page-heading">
        <h1 class="page-title" id="folder-template-title">Modelo de Pastas</h1>
        <p class="page-description">Configure a estrutura de diretórios padrão para organizar seus arquivos de impressão 3D.</p>
    </header>

    <div class="settings-layout settings-module-layout settings-stitch-layout">
        <nav class="settings-secondary-nav settings-stitch-nav" aria-label="Categorias de configurações">
            @foreach (var item in Categories)
            {
                @if (item.Href is null)
                {
                    <button class="settings-stitch-nav-item @(item.IsActive ? "settings-stitch-nav-item-active" : null)"
                            type="button"
                            aria-pressed="@item.IsActive">
                        @item.Label
                    </button>
                }
                else
                {
                    <a class="settings-stitch-nav-item @(item.IsActive ? "settings-stitch-nav-item-active" : null)"
                       href="@item.Href"
                       aria-current="@(item.IsActive ? "page" : null)">
                        @item.Label
                    </a>
                }
            }
        </nav>

        <main class="settings-content settings-module-content settings-folder-template-content" aria-label="Modelo de pastas">
            <div class="settings-folder-template-canvas">
                @if (ModeloPastas is null)
                {
                    <AppStateBlock Variant="empty"
                                   Title="Nenhum modelo de pastas configurado"
                                   Description="A estrutura padrão será exibida aqui quando existir metadado no banco local."
                                   IsCompact="true" />
                }
                else
                {
                    <div class="settings-folder-template-grid">
                        @foreach (var template in Templates)
                        {
                            <section class="settings-folder-template-card" aria-labelledby="@template.TitleId">
                                <div class="settings-folder-template-card-header">
                                    <h2 id="@template.TitleId">
                                        <span class="settings-folder-template-title-icon" aria-hidden="true">
                                            <AppIcon Name="@template.Icon" />
                                        </span>
                                        @template.Title
                                    </h2>

                                    <button type="button" title="Editar modelo de @template.Title" aria-label="Editar modelo de @template.Title">
                                        <AppIcon Name="edit" />
                                    </button>
                                </div>

                                <div class="settings-folder-tree" aria-label="Estrutura de pastas para @template.Title">
                                    <div class="settings-folder-tree-root">
                                        <AppIcon Name="folder" />
                                        <span>@template.Root</span>
                                    </div>

                                    <div class="settings-folder-tree-children">
                                        @foreach (var child in template.Children)
                                        {
                                            <div class="settings-folder-tree-child">
                                                <AppIcon Name="folder" />
                                                <span>@child</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </section>
                        }
                    </div>

                    <section class="settings-folder-template-preview" aria-labelledby="folder-template-preview-title">
                        <h2 id="folder-template-preview-title">Pré-visualização do caminho</h2>

                        <div class="settings-folder-template-path" aria-label="Pré-visualização do caminho final">
                            <span>/</span>
                            @foreach (var segment in PreviewSegments)
                            {
                                @if (segment.IsHighlight)
                                {
                                    <strong>@segment.Value</strong>
                                }
                                else
                                {
                                    <span>@segment.Value</span>
                                }

                                <span>/</span>
                            }
                        </div>
                    </section>
                }

                <footer class="settings-folder-template-actions" aria-label="Ações mockadas do modelo de pastas">
                    <button class="settings-folder-template-save" type="button">Salvar alterações</button>
                </footer>
            </div>
        </main>
    </div>
</section>

@code {
    private static readonly SettingsCategory[] Categories =
    [
        new("Geral", false, "/configuracoes"),
        new("Caminhos", false, "/configuracoes/caminhos"),
        new("Aparência", false, "/configuracoes/aparencia"),
        new("Backup", false, "/configuracoes/backup"),
        new("Modelo de Pastas", true, "/configuracoes/modelo-pastas"),
        new("Dados do App", false, null)
    ];

    private ModeloPastasResumo? ModeloPastas { get; set; }

    private IReadOnlyList<FolderTemplate> Templates =>
        ModeloPastas?.Itens
            .Where(item => item.Nivel == 0)
            .OrderBy(item => item.Ordem)
            .Select(CriarTemplate)
            .ToList()
        ?? [];

    private IReadOnlyList<PathSegment> PreviewSegments =>
        ObterCaminhoPreview()
            .Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select((segmento, indice) => new PathSegment(segmento, indice == 0))
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        ModeloPastas = await ConfiguracoesServico.ObterModeloPastasAsync();
    }

    private FolderTemplate CriarTemplate(ModeloPastasItemResumo raiz)
    {
        var children = ModeloPastas?.Itens
            .Where(item =>
                item.Nivel == raiz.Nivel + 1
                && item.CaminhoRelativo.StartsWith(raiz.CaminhoRelativo, StringComparison.OrdinalIgnoreCase)
                && !string.Equals(item.CaminhoRelativo, raiz.CaminhoRelativo, StringComparison.OrdinalIgnoreCase))
            .OrderBy(item => item.Ordem)
            .Select(item => item.Nome)
            .ToArray()
            ?? [];

        return new FolderTemplate(
            ObterTitulo(raiz.Nome),
            $"folder-template-{raiz.Nome}-title",
            ObterIcone(raiz.Nome),
            raiz.Nome,
            children);
    }

    private string ObterCaminhoPreview()
    {
        return ModeloPastas?.Itens
            .Where(item => item.Nivel > 0)
            .OrderBy(item => item.Ordem)
            .Select(item => item.CaminhoRelativo)
            .FirstOrDefault()
            ?? ModeloPastas?.Itens.OrderBy(item => item.Ordem).Select(item => item.CaminhoRelativo).FirstOrDefault()
            ?? string.Empty;
    }

    private static string ObterTitulo(string nome)
    {
        return nome switch
        {
            "modelo" => "Modelo",
            "imagens" => "Imagens",
            "documentos" => "Documentos",
            "exportacoes" => "Exportações",
            _ => nome
        };
    }

    private static string ObterIcone(string nome)
    {
        return nome switch
        {
            "modelo" => "models",
            "imagens" => "collections",
            _ => "folder"
        };
    }

    private sealed record SettingsCategory(string Label, bool IsActive, string? Href);

    private sealed record FolderTemplate(string Title, string TitleId, string Icon, string Root, string[] Children);

    private sealed record PathSegment(string Value, bool IsHighlight);
}
