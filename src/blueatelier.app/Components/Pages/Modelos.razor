@page "/modelos"
@using BlueAtelier.Application.Contratos
@using BlueAtelier.Application.Modelos
@using BlueAtelier.Domain.Enums
@inject IModeloServico ModeloServico

<section class="models-page" aria-labelledby="models-title">
    <header class="models-header">
        <div class="models-heading">
            <p>Biblioteca visual</p>
            <h1 id="models-title">Modelos</h1>
            <span>Modelos cadastrados e organizados por colecao, status e etapa de producao.</span>
        </div>

        <div class="models-actions" aria-label="Acoes visuais de modelos">
            <button class="models-action models-action-primary" type="button">Novo modelo</button>
            <button class="models-action" type="button">Importar modelo</button>
            <button class="models-action" type="button">Organizar modelos</button>
        </div>
    </header>

    <nav class="models-filters" aria-label="Filtros visuais de modelos">
        @foreach (var filter in Filters)
        {
            <button class="models-filter @(filter.IsActive ? "models-filter-active" : null)" type="button">
                @filter.Label
            </button>
        }
    </nav>

    <div class="models-grid">
        @foreach (var model in Models)
        {
            @if (model.Href is not null)
            {
                <a class="models-card models-card-link" href="@model.Href">
                    <div class="models-card-cover models-cover-@model.Cover" aria-hidden="true">
                        <span class="models-card-shape"></span>
                    </div>

                    <div class="models-card-body">
                        <div class="models-card-title-row">
                            <div>
                                <h2>@model.Name</h2>
                                <p>@model.Collection</p>
                            </div>

                            <span class="models-status models-status-@model.Tone">@model.Status</span>
                        </div>

                        <div class="models-card-meta">
                            <span>@model.Progress</span>
                            <span>@model.Material</span>
                        </div>

                        <div class="models-card-footer">
                            <span>Abrir modelo</span>
                            <AppIcon Name="arrow" />
                        </div>
                    </div>
                </a>
            }
            else
            {
                <article class="models-card">
                    <div class="models-card-cover models-cover-@model.Cover" aria-hidden="true">
                        <span class="models-card-shape"></span>
                    </div>

                    <div class="models-card-body">
                        <div class="models-card-title-row">
                            <div>
                                <h2>@model.Name</h2>
                                <p>@model.Collection</p>
                            </div>

                            <span class="models-status models-status-@model.Tone">@model.Status</span>
                        </div>

                        <div class="models-card-meta">
                            <span>@model.Progress</span>
                            <span>@model.Material</span>
                        </div>

                        <div class="models-card-footer">
                            <span>Abrir modelo</span>
                            <AppIcon Name="arrow" />
                        </div>
                    </div>
                </article>
            }
        }
    </div>

    @if (ShowEmptyState)
    {
        <AppStateBlock
            Variant="empty"
            Title="Nenhum modelo cadastrado ainda."
            Description="Os modelos aparecerão aqui quando forem registrados no banco local."
            IsCompact="true" />
    }
</section>

@code {
    private bool IsLoading { get; set; } = true;

    private IReadOnlyList<ModelIndexItem> Models { get; set; } = [];

    private bool ShowEmptyState => !IsLoading && Models.Count == 0;

    private static readonly ModelsFilter[] Filters =
    [
        new("Todos", true),
        new("Em pintura", false),
        new("Prontos para impressao", false),
        new("Impressos", false),
        new("Favoritos", false),
        new("Arquivos ausentes", false)
    ];

    private static readonly Dictionary<string, ModelVisualMetadata> ModelVisualBySlug = new(StringComparer.OrdinalIgnoreCase)
    {
        ["cthulhu-idol"] = new("idol", "accent"),
        ["deep-one-bust"] = new("bust", "neutral"),
        ["tentacle-beast"] = new("beast", "neutral"),
        ["ancient-cultist"] = new("cultist", "success"),
        ["forgotten-horror"] = new("beast", "neutral"),
        ["abyssal-statue"] = new("statue", "accent")
    };

    private static readonly ModelVisualMetadata DefaultModelVisualMetadata = new("beast", "neutral");

    protected override async Task OnInitializedAsync()
    {
        var modelos = await ModeloServico.ListarResumoAsync();

        Models = modelos
            .Select(CriarCard)
            .ToList();

        IsLoading = false;
    }

    private static ModelIndexItem CriarCard(ModeloResumo resumo)
    {
        var visual = ModelVisualBySlug.GetValueOrDefault(resumo.Slug, DefaultModelVisualMetadata);
        var progress = Math.Clamp(resumo.ProgressoPercentual, 0, 100);

        return new ModelIndexItem(
            resumo.Nome,
            resumo.ColecaoNome,
            FormatStatus(resumo.EtapaAtual),
            FormatProgress(resumo.EtapaAtual, progress),
            FormatMaterial(resumo),
            visual.Tone,
            visual.Cover,
            CriarCaminhoDetalhe(resumo));
    }

    private static string? CriarCaminhoDetalhe(ModeloResumo resumo)
    {
        return resumo.ColecaoSlug.Equals("eldritch-horrors", StringComparison.OrdinalIgnoreCase)
               && resumo.Slug.Equals("cthulhu-idol", StringComparison.OrdinalIgnoreCase)
            ? "/colecoes/eldritch-horrors/modelos/cthulhu-idol"
            : null;
    }

    private static string FormatStatus(EtapaModelo etapa)
    {
        return etapa switch
        {
            EtapaModelo.Preparacao => "Pronto para impressao",
            EtapaModelo.Modelagem => "Modelagem",
            EtapaModelo.Impressao => "Impressao",
            EtapaModelo.Pintura => "Em pintura",
            EtapaModelo.Concluido => "Impresso",
            EtapaModelo.Arquivado => "Arquivado",
            _ => "Planejamento"
        };
    }

    private static string FormatProgress(EtapaModelo etapa, int progress)
    {
        return etapa == EtapaModelo.Arquivado
            ? "Arquivado"
            : $"{progress}%";
    }

    private static string FormatMaterial(ModeloResumo resumo)
    {
        if (!string.IsNullOrWhiteSpace(resumo.MaterialSugerido) && !string.IsNullOrWhiteSpace(resumo.Escala))
        {
            return $"{resumo.MaterialSugerido} / {resumo.Escala}";
        }

        return resumo.MaterialSugerido
               ?? resumo.TipoArquivo
               ?? "Material a definir";
    }

    private sealed record ModelsFilter(string Label, bool IsActive);

    private sealed record ModelVisualMetadata(string Cover, string Tone);

    private sealed record ModelIndexItem(
        string Name,
        string Collection,
        string Status,
        string Progress,
        string Material,
        string Tone,
        string Cover,
        string? Href = null);
}
