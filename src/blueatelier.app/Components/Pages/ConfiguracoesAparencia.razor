@page "/configuracoes/aparencia"
@using BlueAtelier.Application.Contratos
@using BlueAtelier.Application.Modelos
@inject IConfiguracoesServico ConfiguracoesServico

<section class="settings-page settings-module-page settings-stitch-page settings-appearance-page" aria-labelledby="settings-appearance-title">
    <header class="settings-header settings-module-header settings-stitch-header settings-appearance-header page-heading">
        <h1 class="page-title" id="settings-appearance-title">Aparência</h1>
        <p class="page-description">Personalize o tema, as cores e a densidade da interface do Blue Atelier.</p>
    </header>

    <div class="settings-layout settings-module-layout settings-stitch-layout">
        <nav class="settings-secondary-nav settings-stitch-nav" aria-label="Categorias de configurações">
            @foreach (var item in Categories)
            {
                @if (item.Href is null)
                {
                    <button class="settings-stitch-nav-item @(item.IsActive ? "settings-stitch-nav-item-active" : null)"
                            type="button"
                            aria-pressed="@item.IsActive">
                        @item.Label
                    </button>
                }
                else
                {
                    <a class="settings-stitch-nav-item @(item.IsActive ? "settings-stitch-nav-item-active" : null)"
                       href="@item.Href"
                       aria-current="@(item.IsActive ? "page" : null)">
                        @item.Label
                    </a>
                }
            }
        </nav>

        <main class="settings-content settings-module-content settings-appearance-content" aria-label="Configurações de aparência">
            <div class="settings-appearance-grid">
                <section class="settings-appearance-panel settings-appearance-theme-panel" aria-labelledby="appearance-theme-title">
                    <h2 id="appearance-theme-title">Tema</h2>

                    <div class="appearance-theme-options" aria-label="Tema visual">
                        @foreach (var theme in Themes)
                        {
                            <button class="appearance-theme-card @(theme.IsActive ? "appearance-theme-card-active" : null)"
                                    type="button"
                                    aria-pressed="@theme.IsActive">
                                <span class="appearance-theme-preview appearance-theme-preview-@theme.Tone" aria-hidden="true">
                                    <span class="appearance-preview-top">
                                        <span></span>
                                        <span></span>
                                    </span>
                                    <span class="appearance-preview-body">
                                        <span class="appearance-preview-side"></span>
                                        <span class="appearance-preview-lines">
                                            <span></span>
                                            <span></span>
                                        </span>
                                    </span>
                                </span>

                                <span class="appearance-theme-label">
                                    <span class="appearance-radio" aria-hidden="true">
                                        @if (theme.IsActive)
                                        {
                                            <span></span>
                                        }
                                    </span>
                                    <span>@theme.Label</span>
                                </span>
                            </button>
                        }
                    </div>
                </section>

                <section class="settings-appearance-panel settings-appearance-density-panel" aria-labelledby="appearance-density-title">
                    <h2 id="appearance-density-title">Densidade da interface</h2>

                    <div class="appearance-density-options" aria-label="Densidade visual">
                        @foreach (var density in Densities)
                        {
                            <button class="appearance-density-option @(density.IsActive ? "appearance-density-option-active" : null)"
                                    type="button"
                                    aria-pressed="@density.IsActive">
                                <span class="appearance-radio" aria-hidden="true">
                                    @if (density.IsActive)
                                    {
                                        <span></span>
                                    }
                                </span>
                                <span>
                                    <strong>@density.Label</strong>
                                    <small>@density.Description</small>
                                </span>
                            </button>
                        }
                    </div>
                </section>

                <section class="settings-appearance-panel settings-appearance-accent-panel" aria-labelledby="appearance-accent-title">
                    <div class="appearance-accent-header">
                        <div>
                            <h2 id="appearance-accent-title">Cor de destaque</h2>
                            <p>A cor principal usada em botões, links e elementos ativos.</p>
                        </div>

                        <button type="button">Restaurar padrão</button>
                    </div>

                    <div class="appearance-accent-swatches" aria-label="Cores de destaque">
                        @foreach (var swatch in AccentSwatches)
                        {
                            <button class="appearance-accent-swatch @(swatch.IsActive ? "appearance-accent-swatch-active" : null)"
                                    type="button"
                                    title="@swatch.Label"
                                    aria-label="@swatch.Label"
                                    aria-pressed="@swatch.IsActive"
                                    style="@($"--appearance-swatch: {swatch.Color};")">
                                @if (swatch.IsActive)
                                {
                                    <AppIcon Name="check" />
                                }
                            </button>
                        }
                    </div>
                </section>
            </div>

            <footer class="settings-appearance-actions" aria-label="Ações de aparência">
                <button type="button">Cancelar</button>
                <button class="settings-appearance-save" type="button">Salvar alterações</button>
            </footer>
        </main>
    </div>
</section>

@code {
    private static readonly SettingsCategory[] Categories =
    [
        new("Geral", false, "/configuracoes"),
        new("Caminhos", false, "/configuracoes/caminhos"),
        new("Aparência", true, "/configuracoes/aparencia"),
        new("Backup", false, "/configuracoes/backup"),
        new("Modelo de Pastas", false, "/configuracoes/modelo-pastas"),
        new("Dados do App", false, null)
    ];

    private ConfiguracoesAparenciaResumo AparenciaResumo { get; set; } = ConfiguracoesAparenciaPadrao;

    private IReadOnlyList<ThemeOption> Themes =>
    [
        new("Claro", "light", TemaAtivo("light")),
        new("Escuro", "dark", TemaAtivo("dark")),
        new("Automático", "auto", TemaAtivo("system"))
    ];

    private IReadOnlyList<DensityOption> Densities =>
    [
        new("Padrão", "Espaçamento confortável e legível.", DensidadeAtiva("comfortable")),
        new("Compacto", "Mais informações visíveis na tela.", DensidadeAtiva("compact"))
    ];

    private IReadOnlyList<AccentSwatch> AccentSwatches =>
    [
        new("Azul padrão", "blue", "#0058be", CorAtiva("blue")),
        new("Verde secundário", "green", "#466558", CorAtiva("green")),
        new("Dourado terciário", "amber", "#755800", CorAtiva("amber")),
        new("Vermelho sistema", "red", "#ba1a1a", CorAtiva("red")),
        new("Violeta", "violet", "#6750a4", CorAtiva("violet")),
        new("Teal", "teal", "#006a6a", CorAtiva("teal"))
    ];

    private static readonly ConfiguracoesAparenciaResumo ConfiguracoesAparenciaPadrao = new(
        "system",
        "comfortable",
        "blue",
        DateTimeOffset.UtcNow);

    protected override async Task OnInitializedAsync()
    {
        AparenciaResumo = await ConfiguracoesServico.ObterAparenciaAsync();
    }

    private bool TemaAtivo(string tema)
    {
        return string.Equals(AparenciaResumo.Tema, tema, StringComparison.OrdinalIgnoreCase);
    }

    private bool DensidadeAtiva(string densidade)
    {
        return string.Equals(AparenciaResumo.Densidade, densidade, StringComparison.OrdinalIgnoreCase);
    }

    private bool CorAtiva(string cor)
    {
        return string.Equals(AparenciaResumo.CorDestaque, cor, StringComparison.OrdinalIgnoreCase);
    }

    private sealed record SettingsCategory(string Label, bool IsActive, string? Href);

    private sealed record ThemeOption(string Label, string Tone, bool IsActive);

    private sealed record DensityOption(string Label, string Description, bool IsActive);

    private sealed record AccentSwatch(string Label, string Key, string Color, bool IsActive);
}
