@page "/arquivos"
@page "/colecoes/eldritch-horrors/modelos/cthulhu-idol/arquivos"
@using BlueAtelier.Application.Contratos
@using BlueAtelier.Application.Modelos
@using BlueAtelier.Domain.Enums
@inject IArquivoVinculadoServico ArquivoVinculadoServico

<section class="linked-files-page" aria-labelledby="linked-files-title">
    <a class="collection-detail-back" href="/colecoes/eldritch-horrors/modelos/cthulhu-idol">
        <span aria-hidden="true">&lt;</span>
        <span>Voltar para Cthulhu Idol</span>
    </a>

    <header class="linked-files-header">
        <div class="linked-files-cover" aria-hidden="true">
            <span class="linked-files-cover-glow"></span>
            <span class="linked-files-cover-idol"></span>
            <span class="linked-files-cover-base"></span>
            <span class="linked-files-cover-tentacle tentacle-left"></span>
            <span class="linked-files-cover-tentacle tentacle-right"></span>
        </div>

        <div class="linked-files-heading-copy">
            <p>Arquivos Vinculados</p>
            <h1 id="linked-files-title">Cthulhu Idol</h1>
            <span>Cthulhu Idol / Eldritch Horrors</span>
            <small>Arquivos 3D, fatiamento, referencias e notas associados ao modelo.</small>

            <div class="linked-files-summary" aria-label="Resumo de arquivos vinculados">
                @foreach (var item in SummaryItems)
                {
                    <div class="linked-files-summary-card">
                        <span class="linked-files-summary-icon summary-@item.Tone" aria-hidden="true">
                            <AppIcon Name="@item.Icon" />
                        </span>
                        <strong>@item.Value</strong>
                        <span>@item.Label</span>
                    </div>
                }
            </div>
        </div>
    </header>

    <section class="linked-files-actions" aria-label="Acoes visuais de arquivos vinculados">
        <button class="linked-files-action linked-files-action-primary" type="button">
            <span aria-hidden="true">+</span>
            Vincular arquivo
        </button>
        <button class="linked-files-action" type="button">
            <AppIcon Name="folder" />
            Vincular pasta
        </button>
        <button class="linked-files-action" type="button">
            <AppIcon Name="folder" />
            Abrir pasta do modelo
        </button>
        <button class="linked-files-action" type="button">
            <AppIcon Name="settings" />
            Organizar arquivos
        </button>
    </section>

    <nav class="linked-files-filters" aria-label="Filtros visuais de arquivos vinculados">
        @foreach (var filter in Filters)
        {
            <button class="linked-files-filter @(filter.IsActive ? "linked-files-filter-active" : null)" type="button">
                @filter.Label
            </button>
        }
    </nav>

    <div class="linked-files-layout">
        <main class="linked-files-list-area" aria-label="Lista de arquivos vinculados">
            @if (IsLoading)
            {
                <AppStateBlock
                    Variant="loading"
                    Title="Carregando arquivos"
                    Description="Buscando metadados locais de arquivos vinculados."
                    IsCompact="true" />
            }
            else if (FileGroups.Count == 0)
            {
                <AppStateBlock
                    Variant="empty"
                    Title="Nenhum arquivo vinculado"
                    Description="Ainda nao existem metadados de arquivos vinculados no banco local."
                    IsCompact="true" />
            }
            else
            {
                @foreach (var group in FileGroups)
                {
                    <section class="linked-files-section" aria-labelledby="@group.Id">
                        <h2 id="@group.Id">@group.Title</h2>

                        <div class="linked-files-table">
                            @foreach (var file in group.Files)
                            {
                                <article class="linked-file-row linked-file-status-@file.StatusTone">
                                    <div class="linked-file-main">
                                        <span class="linked-file-type-icon type-@file.TypeTone" aria-hidden="true">
                                            @file.Extension
                                        </span>
                                        <div>
                                            <h3>@file.Name</h3>
                                            <p>@file.Description</p>
                                        </div>
                                    </div>

                                    <span class="linked-file-category">@file.Category</span>
                                    <span class="linked-file-size">@file.Size</span>
                                    <span class="linked-file-date">@file.Date</span>

                                    <span class="linked-file-status">
                                        <span aria-hidden="true"></span>
                                        @file.Status
                                    </span>

                                    <div class="linked-file-actions" aria-label="Acoes visuais para @file.Name">
                                        <button type="button" title="Abrir arquivo" aria-label="Abrir arquivo @file.Name">
                                            <AppIcon Name="folder" />
                                        </button>
                                        <button type="button" title="Editar vinculo" aria-label="Editar vinculo de @file.Name">
                                            <AppIcon Name="edit" />
                                        </button>
                                        <button class="linked-file-action-danger" type="button" title="Remover vinculo" aria-label="Remover vinculo de @file.Name">
                                            <AppIcon Name="trash" />
                                        </button>
                                    </div>
                                </article>
                            }
                        </div>
                    </section>
                }
            }
        </main>

        <aside class="linked-files-side-panel" aria-label="Resumo e caminho vinculado">
            <section class="linked-files-info-card">
                <h2>Pasta vinculada</h2>
                <p class="linked-files-path">@PastaVinculada</p>
                <small>Mock visual. Nenhuma pasta real foi aberta ou lida.</small>
            </section>

            <section class="linked-files-info-card linked-files-network-card">
                <span class="linked-files-warning-dot" aria-hidden="true"></span>
                <h2>Caminho de rede offline</h2>
                <p>\\atelier-notebook\atelier-3d\</p>
                <small>Tratado como condicao normal para revisao futura.</small>
            </section>

            <section class="linked-files-info-card">
                <h2>Resumo</h2>
                <dl class="linked-files-stats">
                    <div>
                        <dt>Total</dt>
                        <dd>@($"{Arquivos.Count} arquivos")</dd>
                    </div>
                    <div>
                        <dt>Registrados</dt>
                        <dd>@Arquivos.Count</dd>
                    </div>
                    <div>
                        <dt>Validados</dt>
                        <dd>0</dd>
                    </div>
                    <div>
                        <dt>Rede offline</dt>
                        <dd>0</dd>
                    </div>
                </dl>
            </section>
        </aside>
    </div>
</section>

@code {
    private bool IsLoading { get; set; } = true;

    private IReadOnlyList<ArquivoVinculadoResumo> Arquivos { get; set; } = [];

    private IReadOnlyList<FileGroup> FileGroups { get; set; } = [];

    private IReadOnlyList<SummaryItem> SummaryItems =>
    [
        new(Arquivos.Count.ToString(), "Total", "models", "blue"),
        new(Arquivos.Count.ToString(), "Metadados", "collections", "green"),
        new("0", "Validados", "alert", "amber"),
        new("0", "Rede offline", "folder", "slate")
    ];

    private string PastaVinculada => Arquivos.Count == 0
        ? "Nenhum caminho vinculado"
        : ObterDiretorioTexto(Arquivos[0].CaminhoLocal);

    private static readonly FilterItem[] Filters =
    [
        new("Todos", true),
        new("Modelos 3D", false),
        new("Fatiamento", false),
        new("Referencias", false),
        new("Notas", false),
        new("Outros", false)
    ];

    protected override async Task OnInitializedAsync()
    {
        IsLoading = true;
        Arquivos = await ArquivoVinculadoServico.ListarResumoAsync();
        FileGroups = CriarGrupos(Arquivos);
        IsLoading = false;
    }

    private static IReadOnlyList<FileGroup> CriarGrupos(IReadOnlyList<ArquivoVinculadoResumo> arquivos)
    {
        return arquivos
            .GroupBy(arquivo => ObterGrupo(arquivo.Tipo, arquivo.Extensao))
            .OrderBy(group => group.Key.Order)
            .Select(group => new FileGroup(
                group.Key.Id,
                group.Key.Title,
                group.Select(CriarFileItem).ToArray()))
            .ToList();
    }

    private static FileItem CriarFileItem(ArquivoVinculadoResumo arquivo)
    {
        return new FileItem(
            arquivo.Nome,
            FormatFileExtension(arquivo.Extensao),
            FormatCategory(arquivo.Tipo, arquivo.Extensao),
            FormatFileSize(arquivo.TamanhoBytes),
            FormatDate(arquivo.CriadoEm),
            "Registrado",
            "found",
            FormatTypeTone(arquivo.Tipo, arquivo.Extensao),
            arquivo.CaminhoLocal);
    }

    private static FileGroupDefinition ObterGrupo(TipoArquivoVinculado tipo, string? extensao)
    {
        var extensaoNormalizada = FormatFileExtension(extensao).ToLowerInvariant();

        if (extensaoNormalizada is ".lys" or ".ctb")
        {
            return new FileGroupDefinition(20, "linked-files-slicing", "Fatiamento");
        }

        return tipo switch
        {
            TipoArquivoVinculado.Modelo3D => new FileGroupDefinition(10, "linked-files-3d", "Arquivos 3D"),
            TipoArquivoVinculado.Imagem or TipoArquivoVinculado.Referencia => new FileGroupDefinition(30, "linked-files-references", "Referencias"),
            TipoArquivoVinculado.Documento or TipoArquivoVinculado.Nota => new FileGroupDefinition(40, "linked-files-notes", "Documentos e Notas"),
            _ => new FileGroupDefinition(50, "linked-files-other", "Outros")
        };
    }

    private static string FormatCategory(TipoArquivoVinculado tipo, string? extensao)
    {
        var extensaoNormalizada = FormatFileExtension(extensao).ToLowerInvariant();

        if (extensaoNormalizada is ".lys" or ".ctb")
        {
            return "Fatiamento";
        }

        return tipo switch
        {
            TipoArquivoVinculado.Modelo3D => "Modelo 3D",
            TipoArquivoVinculado.Imagem => "Imagem",
            TipoArquivoVinculado.Documento => "Documento",
            TipoArquivoVinculado.Nota => "Notas",
            TipoArquivoVinculado.Referencia => "Referencias",
            _ => "Outros"
        };
    }

    private static string FormatTypeTone(TipoArquivoVinculado tipo, string? extensao)
    {
        var extensaoNormalizada = FormatFileExtension(extensao).ToLowerInvariant();

        if (extensaoNormalizada is ".lys" or ".ctb")
        {
            return "teal";
        }

        return tipo switch
        {
            TipoArquivoVinculado.Modelo3D => "blue",
            TipoArquivoVinculado.Imagem or TipoArquivoVinculado.Referencia => "image",
            TipoArquivoVinculado.Documento or TipoArquivoVinculado.Nota => "slate",
            _ => "slate"
        };
    }

    private static string FormatFileExtension(string? extensao)
    {
        if (string.IsNullOrWhiteSpace(extensao))
        {
            return ".file";
        }

        var valor = extensao.Trim();

        return valor.StartsWith(".", StringComparison.Ordinal)
            ? valor
            : $".{valor}";
    }

    private static string FormatFileSize(long? tamanhoBytes)
    {
        if (tamanhoBytes is null or <= 0)
        {
            return "--";
        }

        if (tamanhoBytes < 1024)
        {
            return $"{tamanhoBytes} B";
        }

        if (tamanhoBytes < 1024 * 1024)
        {
            return $"{tamanhoBytes.Value / 1024d:0.#} KB";
        }

        return $"{tamanhoBytes.Value / 1024d / 1024d:0.#} MB";
    }

    private static string FormatDate(DateTimeOffset data)
    {
        var elapsed = DateTimeOffset.UtcNow - data.ToUniversalTime();

        if (elapsed < TimeSpan.FromDays(1))
        {
            return "Hoje";
        }

        if (elapsed < TimeSpan.FromDays(2))
        {
            return "Ontem";
        }

        if (elapsed < TimeSpan.FromDays(7))
        {
            return $"{Math.Max(1, (int)elapsed.TotalDays)} dias";
        }

        return data.ToLocalTime().ToString("dd/MM");
    }

    private static string ObterDiretorioTexto(string? caminhoLocal)
    {
        if (string.IsNullOrWhiteSpace(caminhoLocal))
        {
            return "Caminho nao informado";
        }

        var caminho = caminhoLocal.Trim();
        var ultimoSeparador = Math.Max(caminho.LastIndexOf('/'), caminho.LastIndexOf('\\'));

        return ultimoSeparador > 0
            ? caminho[..(ultimoSeparador + 1)]
            : caminho;
    }

    private sealed record SummaryItem(string Value, string Label, string Icon, string Tone);

    private sealed record FilterItem(string Label, bool IsActive);

    private sealed record FileGroup(string Id, string Title, FileItem[] Files);

    private sealed record FileGroupDefinition(int Order, string Id, string Title);

    private sealed record FileItem(
        string Name,
        string Extension,
        string Category,
        string Size,
        string Date,
        string Status,
        string StatusTone,
        string TypeTone,
        string Description);
}
