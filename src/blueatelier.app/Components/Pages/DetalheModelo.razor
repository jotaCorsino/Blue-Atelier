@page "/colecoes/{ColecaoSlug}/modelos/{ModeloSlug}"
@using BlueAtelier.Application.Contratos
@using BlueAtelier.Application.Modelos
@using BlueAtelier.Domain.Enums
@inject IModeloServico ModeloServico
@inject IArquivoVinculadoServico ArquivoVinculadoServico

@if (IsLoading)
{
    <section class="model-detail-page" aria-labelledby="model-detail-loading-title">
        <AppStateBlock
            Variant="loading"
            Title="Carregando modelo"
            Description="Buscando os dados locais do modelo."
            IsCompact="true" />
    </section>
}
else if (Model is null)
{
    <section class="model-detail-page" aria-labelledby="model-detail-not-found-title">
        <a class="collection-detail-back" href="/modelos">
            <span aria-hidden="true">&lt;</span>
            <span>Back to Models</span>
        </a>

        <AppStateBlock
            Variant="unavailable"
            Title="Modelo não encontrado"
            Description="Este modelo não existe no banco local atual."
            ActionLabel="Voltar para Modelos" />
    </section>
}
else
{
<section class="model-detail-page" aria-labelledby="model-detail-title">
    <a class="collection-detail-back" href="@CollectionPath">
        <span aria-hidden="true">&lt;</span>
        <span>Back to @Model.ColecaoNome</span>
    </a>

    <header class="model-detail-heading">
        <div class="model-detail-heading-copy">
            <p class="model-detail-eyebrow">Model Detail</p>
            <h1 id="model-detail-title">@Model.Nome</h1>
            <p>
                @ModelDescription
            </p>
        </div>

        <div class="model-detail-heading-meta" aria-label="Resumo visual do modelo">
            <span class="model-status-pill">@ModelStatus</span>
            <span>@ModelUpdatedAt</span>
            <span>@ModelProgressLabel complete</span>
        </div>
    </header>

    <div class="model-detail-grid">
        <section class="model-detail-visual-column" aria-label="Capa e informacoes do modelo">
            <div class="model-cover-card">
                <div class="model-main-cover" aria-hidden="true">
                    <span class="model-cover-orb"></span>
                    <span class="model-cover-base"></span>
                    <span class="model-cover-tentacle tentacle-one"></span>
                    <span class="model-cover-tentacle tentacle-two"></span>
                    <span class="model-cover-tentacle tentacle-three"></span>
                </div>
            </div>

            <div class="model-title-panel">
                <h2>@Model.Nome</h2>
                <div class="model-breadcrumb-line" aria-label="Colecao do modelo">
                    <span>Collections</span>
                    <span aria-hidden="true">/</span>
                    <a href="@CollectionPath">@Model.ColecaoNome</a>
                    <span class="model-status-pill">@ModelStatus</span>
                </div>

                <div class="model-tag-row" aria-label="Tags do modelo">
                    @foreach (var tag in Tags)
                    {
                        <span>@tag</span>
                    }
                </div>

                <div class="model-progress-block">
                    <div class="model-progress-track" aria-label="@($"{Model.Nome}: {ModelProgressLabel}")">
                        <span style="@($"width: {ModelProgressPercent}%")"></span>
                    </div>
                    <span>@ModelProgressLabel</span>
                </div>
            </div>

            <section class="model-info-card" aria-labelledby="model-info-title">
                <h3 id="model-info-title">Model Info</h3>
                <dl>
                    @foreach (var item in ModelInfo)
                    {
                        <div>
                            <dt>@item.Label</dt>
                            <dd>@item.Value</dd>
                        </div>
                    }
                </dl>
            </section>
        </section>

        <section class="model-detail-workflow-column" aria-label="Checklist e acoes do modelo">
            <section class="model-panel" aria-labelledby="model-checklist-title">
                <h2 id="model-checklist-title">Production Checklist</h2>
                <ul class="model-checklist">
                    @foreach (var item in Checklist)
                    {
                        <li class="@(item.IsCurrent ? "model-check-current" : item.IsDone ? "model-check-done" : null)">
                            <span class="model-check-box" aria-hidden="true">
                                @if (item.IsDone || item.IsCurrent)
                                {
                                    <span>✓</span>
                                }
                            </span>
                            <span>@item.Label</span>
                        </li>
                    }
                </ul>
            </section>

            <section class="model-action-section" aria-labelledby="model-actions-title">
                <h2 id="model-actions-title">Action Grid</h2>
                <div class="model-action-grid">
                    @foreach (var action in Actions)
                    {
                        <button class="model-action-card @(action.IsPrimary ? "model-action-card-primary" : null)" type="button">
                            <AppIcon Name="@action.Icon" />
                            <span>@action.Label</span>
                        </button>
                    }
                </div>
            </section>
        </section>

        <aside class="model-detail-side-column" aria-label="Detalhes relacionados ao modelo">
            <section class="model-panel" aria-labelledby="model-materials-title">
                <h2 id="model-materials-title">Materials</h2>
                <div class="model-material-grid">
                    @foreach (var material in Materials)
                    {
                        <div class="model-material-item">
                            <span class="model-material-swatch material-@material.Tone" aria-hidden="true"></span>
                            <span>@material.Name</span>
                        </div>
                    }
                </div>
            </section>

            <div class="model-side-split">
                <section class="model-panel model-panel-compact" aria-labelledby="model-files-title">
                    <div class="model-panel-heading">
                        <h2 id="model-files-title">Linked Files</h2>
                        <a class="model-gallery-open" href="@($"{ModelPathBase}/arquivos")">
                            Ver arquivos
                        </a>
                    </div>
                    <div class="model-file-list">
                        @if (LinkedFiles.Count == 0)
                        {
                            <AppStateBlock
                                Variant="empty"
                                Title="Nenhum arquivo vinculado"
                                Description="Este modelo ainda nao possui metadados de arquivos vinculados."
                                IsCompact="true" />
                        }
                        else
                        {
                            @foreach (var file in LinkedFiles)
                            {
                                <div class="model-file-item">
                                    <span>@file.Extension</span>
                                    <p>@file.Name</p>
                                </div>
                            }
                        }
                    </div>
                </section>

                <section class="model-panel model-panel-compact" aria-labelledby="model-links-title">
                    <h2 id="model-links-title">Links</h2>
                    <div class="model-link-list">
                        @foreach (var link in Links)
                        {
                            <a href="#" @onclick:preventDefault>@link</a>
                        }
                    </div>
                </section>
            </div>

            <section class="model-panel" aria-labelledby="model-gallery-title">
                <div class="model-panel-heading">
                    <h2 id="model-gallery-title">Gallery</h2>
                    <a class="model-gallery-open" href="@($"{ModelPathBase}/galeria")">
                        Abrir galeria
                    </a>
                </div>
                <div class="model-gallery-grid">
                    @foreach (var reference in References)
                    {
                        <span class="model-gallery-thumb model-gallery-@reference" aria-hidden="true"></span>
                    }
                </div>
            </section>

            <section class="model-panel" aria-labelledby="model-notes-title">
                <h2 id="model-notes-title">Notes</h2>
                <p>
                    @ModelNotes
                </p>
            </section>
        </aside>
    </div>
</section>
}

@code {
    [Parameter]
    public string? ColecaoSlug { get; set; }

    [Parameter]
    public string? ModeloSlug { get; set; }

    private bool IsLoading { get; set; } = true;

    private ModeloDetalhe? Model { get; set; }

    private IReadOnlyList<LinkedFile> LinkedFiles { get; set; } = [];

    private string CollectionPath => Model is null
        ? "/colecoes"
        : $"/colecoes/{Model.ColecaoSlug}";

    private string ModelPathBase => Model is null
        ? "#"
        : $"/colecoes/{Model.ColecaoSlug}/modelos/{Model.Slug}";

    private int ModelProgressPercent => Model is null
        ? 0
        : Math.Clamp(Model.ProgressoPercentual, 0, 100);

    private string ModelProgressLabel => $"{ModelProgressPercent}%";

    private string ModelStatus => Model is null
        ? string.Empty
        : FormatStatus(Model.EtapaAtual);

    private string ModelUpdatedAt => Model is null
        ? string.Empty
        : FormatUpdatedAt(Model.AtualizadoEm);

    private string ModelDescription => string.IsNullOrWhiteSpace(Model?.Descricao)
        ? "Eldritch centerpiece with heavy texture, tentacles, stone base, and layered dark green painting."
        : Model.Descricao;

    private string ModelNotes =>
        "Focusing on deep green base and dark washes. Emphasizing texture on the tentacles before the final purple glaze.";

    private IReadOnlyList<ModelInfoItem> ModelInfo => Model is null
        ? []
        :
        [
            new("Current stage", ModelStatus),
            new("Progress", ModelProgressLabel),
            new("File type", FormatOptional(Model.TipoArquivo)),
            new("Scale", FormatOptional(Model.Escala)),
            new("Estimated time", FormatOptional(Model.TempoEstimado)),
            new("Suggested material", FormatOptional(Model.MaterialSugerido))
        ];

    private IReadOnlyList<MaterialItem> Materials => Model is null
        ? []
        :
        [
            new(FormatOptional(Model.MaterialSugerido), "resin"),
            new("Primer black", "primer"),
            new("Deep green paint", "green"),
            new("Purple wash", "purple")
        ];

    private static readonly string[] Tags =
    [
        "idol",
        "resin",
        "painting",
        "cosmic horror"
    ];

    private static readonly ChecklistItem[] Checklist =
    [
        new("Arquivo conferido", true, false),
        new("Suportes adicionados", true, false),
        new("Fatiado", true, false),
        new("Impresso", true, false),
        new("Lavado", true, false),
        new("Curado", true, false),
        new("Primer", false, true),
        new("Pintura", false, false)
    ];

    private static readonly ModelAction[] Actions =
    [
        new("Editar modelo", "edit", false),
        new("Abrir pasta", "folder", true),
        new("Revisar preparo", "check", false),
        new("Adicionar referencia", "image", false)
    ];

    private static readonly string[] Links =
    [
        "Dark Paint Guide",
        "Inspiration Board"
    ];

    private static readonly string[] References =
    [
        "orb",
        "shield",
        "hound",
        "stone",
        "wash"
    ];

    protected override async Task OnParametersSetAsync()
    {
        IsLoading = true;
        LinkedFiles = [];
        Model = await ModeloServico.ObterDetalhePorSlugAsync(
            ColecaoSlug ?? string.Empty,
            ModeloSlug ?? string.Empty);

        if (Model is not null)
        {
            var arquivos = await ArquivoVinculadoServico.ListarPorModeloAsync(Model.Id);
            LinkedFiles = arquivos
                .Select(CriarLinkedFile)
                .ToList();
        }

        IsLoading = false;
    }

    private static string FormatStatus(EtapaModelo etapa)
    {
        return etapa switch
        {
            EtapaModelo.Preparacao => "Preparing",
            EtapaModelo.Modelagem => "Modeling",
            EtapaModelo.Impressao => "Printing",
            EtapaModelo.Pintura => "In Painting",
            EtapaModelo.Concluido => "Finished",
            EtapaModelo.Arquivado => "Archived",
            _ => "Planning"
        };
    }

    private static string FormatOptional(string? value)
    {
        return string.IsNullOrWhiteSpace(value)
            ? "Not defined"
            : value;
    }

    private static LinkedFile CriarLinkedFile(ArquivoVinculadoResumo arquivo)
    {
        return new LinkedFile(FormatFileExtension(arquivo.Extensao), arquivo.Nome);
    }

    private static string FormatFileExtension(string? extensao)
    {
        if (string.IsNullOrWhiteSpace(extensao))
        {
            return ".file";
        }

        var valor = extensao.Trim();

        return valor.StartsWith(".", StringComparison.Ordinal)
            ? valor
            : $".{valor}";
    }

    private static string FormatUpdatedAt(DateTimeOffset updatedAt)
    {
        var elapsed = DateTimeOffset.UtcNow - updatedAt.ToUniversalTime();

        if (elapsed < TimeSpan.FromDays(1))
        {
            return "Updated today";
        }

        if (elapsed < TimeSpan.FromDays(2))
        {
            return "Updated yesterday";
        }

        if (elapsed < TimeSpan.FromDays(7))
        {
            return $"Updated {Math.Max(1, (int)elapsed.TotalDays)} days ago";
        }

        if (elapsed < TimeSpan.FromDays(14))
        {
            return "Updated 1 week ago";
        }

        if (elapsed < TimeSpan.FromDays(31))
        {
            return $"Updated {Math.Max(2, (int)(elapsed.TotalDays / 7))} weeks ago";
        }

        return "Updated 1 month ago";
    }

    private sealed record ModelInfoItem(string Label, string Value);

    private sealed record ChecklistItem(string Label, bool IsDone, bool IsCurrent);

    private sealed record ModelAction(string Label, string Icon, bool IsPrimary);

    private sealed record LinkedFile(string Extension, string Name);

    private sealed record MaterialItem(string Name, string Tone);
}
