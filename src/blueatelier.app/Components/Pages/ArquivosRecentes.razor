@page "/arquivos-recentes"

<section class="recent-files-page" aria-labelledby="recent-files-title">
    <header class="recent-files-header">
        <div class="recent-files-heading">
            <p>Historico visual do atelier</p>
            <h1 id="recent-files-title">Arquivos Recentes</h1>
            <span>Ultimos arquivos acessados, importados ou vinculados ao atelier.</span>
        </div>

        <div class="recent-files-overview" role="status">
            <span class="recent-files-overview-dot" aria-hidden="true"></span>
            <div>
                <strong>8 arquivos mockados</strong>
                <small>Nenhum arquivo real foi lido nesta tela</small>
            </div>
        </div>
    </header>

    <section class="recent-files-actions" aria-label="Acoes visuais de arquivos recentes">
        <button class="recent-files-action recent-files-action-primary" type="button">
            <AppIcon Name="upload" />
            Importar arquivo
        </button>
        <button class="recent-files-action" type="button">
            <AppIcon Name="folder" />
            Vincular pasta
        </button>
        <button class="recent-files-action" type="button">
            <AppIcon Name="folder" />
            Abrir pasta base
        </button>
        <button class="recent-files-action" type="button">
            <AppIcon Name="trash" />
            Limpar historico
        </button>
    </section>

    <nav class="recent-files-filters" aria-label="Filtros visuais de arquivos recentes">
        @foreach (var filter in Filters)
        {
            <button class="recent-files-filter @(filter.IsActive ? "recent-files-filter-active" : null)" type="button">
                @filter.Label
            </button>
        }
    </nav>

    <section class="recent-files-summary" aria-label="Resumo visual de arquivos recentes">
        @foreach (var item in SummaryItems)
        {
            <article class="recent-files-summary-card">
                <span class="recent-files-summary-icon summary-@item.Tone" aria-hidden="true">
                    <AppIcon Name="@item.Icon" />
                </span>
                <div>
                    <strong>@item.Value</strong>
                    <span>@item.Label</span>
                </div>
            </article>
        }

        <article class="recent-files-base-card">
            <span>Pasta base mockada</span>
            <strong>D:\atelier-3d\</strong>
            <small>Historico visual. Nada real foi lido, aberto ou removido.</small>
        </article>
    </section>

    <section class="recent-files-board" aria-label="Lista de arquivos recentes">
        <div class="recent-files-board-header">
            <div>
                <h2>Ultimos arquivos</h2>
                <p>Acessos, importacoes e vinculos recentes em ordem visual.</p>
            </div>

            <span>Atualizado visualmente hoje</span>
        </div>

        <div class="recent-files-table" role="table" aria-label="Arquivos recentes mockados">
            <div class="recent-files-table-head" role="row">
                <span>Nome do arquivo</span>
                <span>Contexto</span>
                <span>Categoria</span>
                <span>Tamanho</span>
                <span>Status</span>
                <span>Acesso</span>
                <span>Acoes</span>
            </div>

            @foreach (var file in RecentFiles)
            {
                <article class="recent-file-row recent-file-status-@file.StatusTone" role="row">
                    <div class="recent-file-main">
                        <span class="recent-file-type type-@file.TypeTone" aria-hidden="true">
                            @file.Extension
                        </span>
                        <div>
                            <h3>@file.Name</h3>
                            <p>@file.Path</p>
                        </div>
                    </div>

                    <div class="recent-file-context">
                        <AppIcon Name="folder" />
                        <span>@file.Context</span>
                    </div>

                    <span class="recent-file-category">@file.Category</span>
                    <span class="recent-file-size">@file.Size</span>

                    <span class="recent-file-status">
                        <span aria-hidden="true"></span>
                        @file.Status
                    </span>

                    <span class="recent-file-date">@file.AccessedAt</span>

                    <div class="recent-file-actions" aria-label="Acoes visuais para @file.Name">
                        <button type="button" title="Abrir arquivo" aria-label="Abrir arquivo @file.Name">
                            <AppIcon Name="folder" />
                        </button>
                        <button type="button" title="Ver contexto" aria-label="Ver contexto de @file.Name">
                            <AppIcon Name="search" />
                        </button>
                        <button type="button" title="Fixar arquivo" aria-label="Fixar arquivo @file.Name">
                            <AppIcon Name="favorites" />
                        </button>
                        <button class="recent-file-action-danger" type="button" title="Remover do historico" aria-label="Remover @file.Name do historico">
                            <AppIcon Name="trash" />
                        </button>
                    </div>
                </article>
            }
        </div>
    </section>
</section>

