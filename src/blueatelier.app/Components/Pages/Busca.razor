@page "/busca"
@using BlueAtelier.Application.Contratos
@using BlueAtelier.Application.Modelos
@inject IBuscaServico BuscaServico

<section class="search-page" aria-labelledby="search-title">
    <header class="search-header">
        <div class="search-heading">
            <p>Busca global</p>
            <h1 id="search-title">Busca</h1>
            <span>Encontre modelos, colecoes, imagens, arquivos vinculados e links favoritos do atelier.</span>
        </div>

        <div class="search-header-meta" aria-label="Resumo visual da busca">
            <span>@TextoTotalResultados</span>
            <span>Busca simples local</span>
        </div>
    </header>

    <section class="search-panel" aria-label="Busca local simples">
        <label class="search-input-shell">
            <AppIcon Name="search" />
            <input type="search"
                   placeholder="Buscar no atelier..."
                   @bind="TermoBusca"
                   @bind:event="oninput"
                   @onkeydown="TratarTeclaBuscaAsync" />
            <button type="button" @onclick="ExecutarBuscaAsync">Buscar</button>
        </label>

        <div class="search-suggestions" aria-label="Sugestoes rapidas">
            <span>Sugestoes rapidas</span>
            @foreach (var suggestion in Suggestions)
            {
                <button type="button" @onclick="() => AplicarSugestaoAsync(suggestion)">@suggestion</button>
            }
        </div>
    </section>

    <nav class="search-filters" aria-label="Filtros visuais de busca">
        @foreach (var filter in Filters)
        {
            <button class="search-filter @(filter.IsActive ? "search-filter-active" : null)" type="button">
                @filter.Label
            </button>
        }
    </nav>

    <section class="search-model-results" aria-labelledby="search-models-title">
        <div class="search-section-heading">
            <div>
                <h2 id="search-models-title">Modelos</h2>
                <p>Resultados mais proximos encontrados no atelier.</p>
            </div>

            <a href="/modelos">Ver todos</a>
        </div>

        <div class="search-model-grid">
            @if (IsLoading)
            {
                <AppStateBlock
                    Variant="loading"
                    Title="Buscando modelos"
                    Description="Consultando os dados locais do atelier."
                    IsCompact="true" />
            }
            else if (ModelResults.Count == 0)
            {
                <AppStateBlock
                    Variant="no-results"
                    Title="Nenhum modelo encontrado"
                    Description="Tente outro termo ou limpe a busca."
                    IsCompact="true" />
            }
            else
            {
                @foreach (var model in ModelResults)
                {
                    @if (model.Href is not null)
                    {
                        <a class="search-model-card" href="@model.Href">
                            <div class="search-model-cover search-model-cover-@model.Cover" aria-hidden="true">
                                <span class="search-model-shape"></span>
                                <span class="search-bookmark"><AppIcon Name="favorites" /></span>
                            </div>

                            <div class="search-model-body">
                                <div class="search-result-title-row">
                                    <h3>@model.Name</h3>
                                    <span>@model.Tag</span>
                                </div>
                                <p>@model.Description</p>
                                <div class="search-score">
                                    <span style="width: @model.Score"></span>
                                </div>
                                <div class="search-result-foot">
                                    <small>@model.Context</small>
                                    <small>@model.Date</small>
                                </div>
                            </div>
                        </a>
                    }
                    else
                    {
                        <article class="search-model-card">
                            <div class="search-model-cover search-model-cover-@model.Cover" aria-hidden="true">
                                <span class="search-model-shape"></span>
                                <span class="search-bookmark"><AppIcon Name="favorites" /></span>
                            </div>

                            <div class="search-model-body">
                                <div class="search-result-title-row">
                                    <h3>@model.Name</h3>
                                    <span>@model.Tag</span>
                                </div>
                                <p>@model.Description</p>
                                <div class="search-score">
                                    <span style="width: @model.Score"></span>
                                </div>
                                <div class="search-result-foot">
                                    <small>@model.Context</small>
                                    <small>@model.Date</small>
                                </div>
                            </div>
                        </article>
                    }
                }
            }
        </div>
    </section>

    <section class="search-results-board" aria-labelledby="search-results-title">
        <div class="search-section-heading">
            <div>
                <h2 id="search-results-title">Resultados</h2>
                <p>Itens relacionados a modelos, colecoes, imagens, links e arquivos vinculados.</p>
            </div>

            <span>Banco local</span>
        </div>

        <div class="search-result-list">
            @if (IsLoading)
            {
                <AppStateBlock
                    Variant="loading"
                    Title="Buscando resultados"
                    Description="Consultando apenas metadados persistidos no banco local."
                    IsCompact="true" />
            }
            else if (Results.Count == 0)
            {
                <AppStateBlock
                    Variant="no-results"
                    Title="Nenhum resultado encontrado"
                    Description="A busca simples ainda consulta somente dados persistidos no banco local."
                    IsCompact="true" />
            }
            else
            {
                @foreach (var result in Results)
                {
                    @if (result.Href is not null)
                    {
                        <a class="search-result-row" href="@result.Href">
                            <span class="search-result-icon search-result-icon-@result.Tone" aria-hidden="true">
                                <AppIcon Name="@result.Icon" />
                            </span>

                            <span class="search-result-copy">
                                <span class="search-result-type">@result.Type</span>
                                <strong>@result.Name</strong>
                                <small>@result.Description</small>
                            </span>

                            <span class="search-result-context">
                                <span>@result.Context</span>
                                <small>@result.Date</small>
                            </span>

                            <span class="search-result-tag">@result.Tag</span>
                            <span class="search-result-action" aria-label="Abrir resultado"><AppIcon Name="arrow" /></span>
                        </a>
                    }
                    else
                    {
                        <article class="search-result-row">
                            <span class="search-result-icon search-result-icon-@result.Tone" aria-hidden="true">
                                <AppIcon Name="@result.Icon" />
                            </span>

                            <span class="search-result-copy">
                                <span class="search-result-type">@result.Type</span>
                                <strong>@result.Name</strong>
                                <small>@result.Description</small>
                            </span>

                            <span class="search-result-context">
                                <span>@result.Context</span>
                                <small>@result.Date</small>
                            </span>

                            <span class="search-result-tag">@result.Tag</span>
                            <span class="search-result-action" aria-label="Abrir resultado"><AppIcon Name="arrow" /></span>
                        </article>
                    }
                }
            }
        </div>
    </section>

    <aside class="search-summary" aria-label="Resumo visual de busca">
        @foreach (var item in Summary)
        {
            <div class="search-summary-card">
                <strong>@item.Value</strong>
                <span>@item.Label</span>
            </div>
        }

        <div class="search-summary-note">
            <h2>Busca simples local</h2>
            <p>A consulta usa somente dados persistidos no banco local. Nenhum arquivo real e lido e nenhum link externo e aberto.</p>
        </div>
    </aside>
</section>

@code {
    private static readonly string[] Suggestions =
    [
        "Cthulhu",
        "Eldritch",
        "pintura",
        "referencia",
        "STL",
        "pedra",
        "wash"
    ];

    private static readonly SearchFilter[] Filters =
    [
        new("Todos", true),
        new("Modelos", false),
        new("Colecoes", false),
        new("Imagens", false),
        new("Arquivos vinculados", false),
        new("Links favoritos", false)
    ];

    private bool IsLoading { get; set; } = true;

    private string TermoBusca { get; set; } = string.Empty;

    private IReadOnlyList<BuscaResultado> BuscaResults { get; set; } = [];

    private IReadOnlyList<SearchModelResult> ModelResults => BuscaResults
        .Where(resultado => resultado.Tipo == "Modelo")
        .Take(2)
        .Select(CriarModeloResultado)
        .ToList();

    private IReadOnlyList<SearchResult> Results => BuscaResults
        .Select(CriarResultado)
        .ToList();

    private IReadOnlyList<SearchSummaryItem> Summary =>
    [
        new(Results.Count.ToString(), "Resultados"),
        new(Results.Count(item => item.Type == "Modelo").ToString(), "Modelos"),
        new(Results.Count(item => item.Type == "Imagem").ToString(), "Imagens"),
        new(Results.Count(item => item.Type == "Favorito").ToString(), "Links")
    ];

    private string TextoTotalResultados => Results.Count == 1
        ? "1 resultado local"
        : $"{Results.Count} resultados locais";

    protected override async Task OnInitializedAsync()
    {
        await BuscarAsync();
    }

    private async Task ExecutarBuscaAsync()
    {
        await BuscarAsync();
    }

    private async Task TratarTeclaBuscaAsync(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            await BuscarAsync();
        }
    }

    private async Task AplicarSugestaoAsync(string suggestion)
    {
        TermoBusca = suggestion;
        await BuscarAsync();
    }

    private async Task BuscarAsync()
    {
        IsLoading = true;
        BuscaResults = await BuscaServico.BuscarAsync(TermoBusca);
        IsLoading = false;
    }

    private static SearchModelResult CriarModeloResultado(BuscaResultado resultado)
    {
        return new SearchModelResult(
            resultado.Titulo,
            resultado.Descricao,
            resultado.Contexto,
            FormatarData(resultado.AtualizadoEm),
            resultado.Tipo,
            $"{Math.Clamp(resultado.Relevancia, 20, 100)}%",
            ObterCapaModelo(resultado),
            resultado.Rota);
    }

    private static SearchResult CriarResultado(BuscaResultado resultado)
    {
        return new SearchResult(
            resultado.Titulo,
            resultado.Tipo,
            resultado.Descricao,
            resultado.Contexto,
            FormatarData(resultado.AtualizadoEm),
            resultado.Tipo.ToLowerInvariant(),
            resultado.Icone,
            resultado.TomVisual,
            resultado.Rota);
    }

    private static string ObterCapaModelo(BuscaResultado resultado)
    {
        var texto = $"{resultado.Titulo} {resultado.Descricao}";

        if (texto.Contains("statue", StringComparison.OrdinalIgnoreCase)
            || texto.Contains("estatua", StringComparison.OrdinalIgnoreCase))
        {
            return "statue";
        }

        return "idol";
    }

    private static string FormatarData(DateTimeOffset data)
    {
        var dias = (DateTimeOffset.UtcNow.Date - data.UtcDateTime.Date).Days;

        return dias switch
        {
            <= 0 => "Hoje",
            1 => "Ontem",
            < 7 => $"{dias} dias",
            < 14 => "Semana passada",
            _ => data.ToString("dd/MM/yyyy")
        };
    }

    private sealed record SearchFilter(string Label, bool IsActive);

    private sealed record SearchModelResult(
        string Name,
        string Description,
        string Context,
        string Date,
        string Tag,
        string Score,
        string Cover,
        string? Href = null);

    private sealed record SearchResult(
        string Name,
        string Type,
        string Description,
        string Context,
        string Date,
        string Tag,
        string Icon,
        string Tone,
        string? Href = null);

    private sealed record SearchSummaryItem(string Value, string Label);
}
