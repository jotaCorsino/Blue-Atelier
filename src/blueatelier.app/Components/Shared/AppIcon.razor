<svg class="app-icon @Class"
     aria-hidden="@(string.IsNullOrWhiteSpace(Title) ? "true" : "false")"
     fill="none"
     focusable="false"
     stroke="currentColor"
     stroke-linecap="round"
     stroke-linejoin="round"
     stroke-width="1.9"
     viewBox="0 0 24 24">
    @if (!string.IsNullOrWhiteSpace(Title))
    {
        <title>@Title</title>
    }

    @switch (IconName)
    {
        case "home":
            <path d="M4 10.5 12 4l8 6.5" />
            <path d="M6.5 9.5V20h4.25v-5.25h2.5V20h4.25V9.5" />
            break;
        case "collections":
            <path d="M4 7.5h6l1.7 2H20v8.75A1.75 1.75 0 0 1 18.25 20H5.75A1.75 1.75 0 0 1 4 18.25Z" />
            <path d="M4 7.5V6.75A1.75 1.75 0 0 1 5.75 5h4.6l1.45 1.7" />
            break;
        case "models":
            <path d="m12 3.75 7 3.9v8.7l-7 3.9-7-3.9v-8.7Z" />
            <path d="m5.35 7.85 6.65 3.7 6.65-3.7" />
            <path d="M12 11.55v8.45" />
            break;
        case "print":
            <path d="M7 8V4.75h10V8" />
            <path d="M7 17H5.75A1.75 1.75 0 0 1 4 15.25v-4.5A1.75 1.75 0 0 1 5.75 9h12.5A1.75 1.75 0 0 1 20 10.75v4.5A1.75 1.75 0 0 1 18.25 17H17" />
            <path d="M7 14h10v5.25H7Z" />
            break;
        case "recent":
            <path d="M12 7.5v5l3 2" />
            <path d="M5.2 8.2A8 8 0 1 1 4.4 15" />
            <path d="M4.5 5.25v3.5h3.5" />
            break;
        case "materials":
            <path d="M5 8.25 12 4l7 4.25-7 4.25Z" />
            <path d="m5 12 7 4.25L19 12" />
            <path d="m5 15.75 7 4.25 7-4.25" />
            break;
        case "favorites":
            <path d="M12 20.25s-7.5-4.6-7.5-10.15A4.1 4.1 0 0 1 12 7.8a4.1 4.1 0 0 1 7.5 2.3c0 5.55-7.5 10.15-7.5 10.15Z" />
            break;
        case "search":
            <circle cx="10.75" cy="10.75" r="5.75" />
            <path d="m15.25 15.25 4.25 4.25" />
            break;
        case "settings":
            <path d="M12 8.25a3.75 3.75 0 1 0 0 7.5 3.75 3.75 0 0 0 0-7.5Z" />
            <path d="M18.25 13.65a6.3 6.3 0 0 0 .05-1.65l1.8-1.35-1.75-3.05-2.1.85a6.1 6.1 0 0 0-1.35-.8L14.6 5.4h-3.5l-.3 2.25c-.48.2-.93.46-1.35.8l-2.1-.85-1.75 3.05L7.4 12a6.3 6.3 0 0 0 .05 1.65L5.6 15l1.75 3.05 2.15-.85c.4.32.84.58 1.3.77l.3 2.28h3.5l.3-2.28c.47-.2.9-.45 1.3-.77l2.15.85L20.1 15Z" />
            break;
        case "edit":
            <path d="M4.75 19.25h4.1L18.8 9.3a2.15 2.15 0 0 0-3.05-3.05L5.8 16.2Z" />
            <path d="m14.65 7.35 3 3" />
            break;
        case "folder":
            <path d="M4 7.5h6l1.7 2H20v8.75A1.75 1.75 0 0 1 18.25 20H5.75A1.75 1.75 0 0 1 4 18.25Z" />
            break;
        case "image":
            <path d="M5.75 5h12.5A1.75 1.75 0 0 1 20 6.75v10.5A1.75 1.75 0 0 1 18.25 19H5.75A1.75 1.75 0 0 1 4 17.25V6.75A1.75 1.75 0 0 1 5.75 5Z" />
            <path d="m6.5 16 3.15-3.15a1.2 1.2 0 0 1 1.7 0L13 14.5l1.15-1.15a1.2 1.2 0 0 1 1.7 0L18 15.5" />
            <circle cx="15.6" cy="9.1" r="1.1" />
            break;
        case "arrow":
            <path d="M5 12h14" />
            <path d="m13 6 6 6-6 6" />
            break;
    }
</svg>

@code {
    [Parameter]
    public string Name { get; set; } = "home";

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public string? Title { get; set; }

    private string IconName => Name.Trim().ToLowerInvariant();
}
